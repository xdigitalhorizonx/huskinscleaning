---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import { site } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const title = `Contact — Open a Channel | ${site.short}`;
const description =
  "Open a channel with Forward Observations Group. Bookings, collabs, press, tips from the field, or just comms — send a transmission.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Contact", url: "/contact/" },
];
const schema = [breadcrumbSchema(crumbs)];

const channels = [
  { icon: "mail", label: "Direct Comms", value: site.email, href: `mailto:${site.email}` },
  { icon: "youtube", label: "YouTube", value: "@forwardobservations", href: site.social.youtube },
  { icon: "spotify", label: "Spotify", value: "The FO Podcast", href: site.social.spotify },
  { icon: "instagram", label: "Instagram", value: "@forwardobservations", href: site.social.instagram },
  { icon: "x", label: "X", value: "@forwardobsgroup", href: site.social.x },
  { icon: "tiktok", label: "TikTok", value: "@forwardobservations", href: site.social.tiktok },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="Contact" jp="連絡" variant="cyan"
    title="Open a Channel"
    lead="Bookings, collabs, press, a tip from the field, or just comms. Send a transmission and we'll pick it up from the post."
    crumbs={crumbs}
  />

  <section class="section">
    <div class="container comms">
      <!-- Terminal form -->
      <div class="panel is-red comms-form">
        <div class="comms-head mono">
          <span><span class="status-dot"></span> SECURE TERMINAL</span>
          <span class="text-amber jp">送信</span>
        </div>
        <form id="comms-form" class="form">
          <div class="field">
            <label for="name" class="mono">CALLSIGN / NAME</label>
            <input id="name" name="name" type="text" required autocomplete="name" placeholder="Who's transmitting?" />
          </div>
          <div class="field">
            <label for="email" class="mono">RETURN FREQUENCY / EMAIL</label>
            <input id="email" name="email" type="email" required autocomplete="email" placeholder="you@channel.net" />
          </div>
          <div class="field">
            <label for="subject" class="mono">TRANSMISSION TYPE</label>
            <select id="subject" name="subject">
              <option>Booking / Guest</option>
              <option>Collab / Partnership</option>
              <option>Press / Media</option>
              <option>Field Tip</option>
              <option>Supply / Order</option>
              <option>Just Comms</option>
            </select>
          </div>
          <div class="field">
            <label for="message" class="mono">MESSAGE</label>
            <textarea id="message" name="message" rows="5" required placeholder="Send it."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-block">
            <Icon name="send" size={18} /> Transmit
          </button>
          <p id="form-status" class="form-status mono" hidden></p>
        </form>
      </div>

      <!-- Channels -->
      <aside class="comms-side">
        <h2 class="h3 display">All frequencies</h2>
        <p class="muted mt-1">Prefer to reach us where we already live? Every channel below is monitored — some more than others.</p>
        <div class="channels mt-4">
          {channels.map((c) => (
            <a href={c.href} target={c.href.startsWith("mailto") ? undefined : "_blank"} rel="noopener" class="channel">
              <span class="ch-icon"><Icon name={c.icon} size={20} /></span>
              <span class="ch-main">
                <span class="ch-label mono">{c.label}</span>
                <span class="ch-value">{c.value}</span>
              </span>
              <Icon name="arrow-up-right" size={16} class="ch-arrow" />
            </a>
          ))}
        </div>
        <div class="comms-note panel is-cyan mono mt-4">
          <Icon name="alert" size={16} />
          <span>Channels get pulled without warning. If one goes dark, check the Vault or try direct comms.</span>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .comms {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }
  @media (max-width: 860px) { .comms { grid-template-columns: 1fr; } }

  .comms-head {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted); padding-bottom: 0.9rem; margin-bottom: 1.1rem;
    border-bottom: 1px solid var(--line);
  }
  .form { display: grid; gap: 1rem; }
  .field { display: grid; gap: 0.4rem; }
  .field label {
    font-size: 0.66rem; letter-spacing: 0.16em; color: var(--amber);
  }
  .field input, .field select, .field textarea {
    width: 100%;
    background: var(--void);
    border: 1px solid var(--line);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 0.98rem;
    padding: 0.8rem 0.9rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .field textarea { resize: vertical; }
  .field input::placeholder, .field textarea::placeholder { color: var(--dim); }
  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none;
    border-color: var(--red);
    box-shadow: 0 0 0 1px var(--red), var(--glow-red);
  }
  .form-status {
    margin: 0; padding: 0.8rem;
    border: 1px solid var(--lime); color: var(--lime);
    background: rgba(77, 255, 158, 0.06);
    font-size: 0.8rem; letter-spacing: 0.06em;
  }

  .comms-side .muted { max-width: 40ch; font-size: 0.95rem; }
  .channels { display: grid; gap: 0.6rem; }
  .channel {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.9rem 1rem;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--body);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s var(--ease);
  }
  .channel:hover { border-color: var(--cyan); background: var(--surface-2); transform: translateX(4px); }
  .ch-icon { color: var(--cyan); flex: none; }
  .ch-main { display: flex; flex-direction: column; flex: 1; min-width: 0; }
  .ch-label { font-size: 0.64rem; letter-spacing: 0.14em; color: var(--dim); text-transform: uppercase; }
  .ch-value { color: var(--ink); font-weight: 500; }
  .channel :global(.ch-arrow) { color: var(--muted); flex: none; }

  .comms-note {
    display: flex; align-items: flex-start; gap: 0.7rem;
    font-size: 0.76rem; letter-spacing: 0.04em; line-height: 1.6; color: var(--muted);
  }
  .comms-note :global(svg) { color: var(--cyan); flex: none; margin-top: 0.1rem; }
</style>

<script is:inline define:vars={{ email: site.email }}>
  const form = document.getElementById("comms-form");
  const status = document.getElementById("form-status");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const name = String(data.get("name") || "");
    const from = String(data.get("email") || "");
    const subject = String(data.get("subject") || "Comms");
    const message = String(data.get("message") || "");
    const body = `${message}\n\n— ${name} (${from})`;
    const href = `mailto:${email}?subject=${encodeURIComponent("[FOG] " + subject)}&body=${encodeURIComponent(body)}`;
    window.location.href = href;
    if (status) {
      status.hidden = false;
      status.textContent = "// TRANSMISSION QUEUED — your mail client should be opening. If not, reach us at " + email;
    }
  });
</script>
