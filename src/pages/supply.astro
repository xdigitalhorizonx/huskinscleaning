---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import ProductCard from "../components/ProductCard.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, products } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const title = `Supply — Kit for the Observant | ${site.short}`;
const description =
  "Apparel and kit from Forward Observations Group. Heavyweight tees, fleece, caps, PVC patches and morale gear. Limited drops — when it's gone, it's gone.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Supply", url: "/supply/" },
];
const schema = [breadcrumbSchema(crumbs)];
const drop = products.find((p) => p.status === "DROP") ?? products[0];
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="Supply" jp="補給" variant="red"
    title="Supply"
    lead="We make the stuff we'd actually wear — packed, rained on, forgotten in a truck, and still standing. Drops are limited by design."
    crumbs={crumbs}
  />

  <!-- Current drop banner -->
  <section class="section-tight drop-band scanlines">
    <div class="grid-floor"></div>
    <div class="container drop-inner">
      <div class="drop-copy">
        <span class="tag is-cyan"><span class="status-dot"></span> LIVE DROP <span class="jp">新着</span></span>
        <h2 class="h2 display mt-2">{drop.name}</h2>
        <p class="lead mt-1">{drop.colorway} · {drop.type} · {drop.price}</p>
        <a href="#catalog" class="btn btn-cyan mt-3"><Icon name="bag" size={16} /> View the Drop</a>
      </div>
      <div class="drop-glyph jp" aria-hidden="true">{drop.jp}</div>
    </div>
  </section>

  <!-- Catalog -->
  <section class="section" id="catalog">
    <div class="container">
      <SectionHead eyebrow="Catalog" jp="目録" variant="amber" title="Standard issue" />
      <div class="grid grid-3 mt-6">
        {products.map((p) => <ProductCard product={p} />)}
      </div>
      <p class="supply-note mono mt-6">
        <Icon name="alert" size={15} /> Colorways rotate and sell out permanently. Prices in USD. Ships worldwide from home station.
      </p>
    </div>
  </section>

  <!-- Doctrine -->
  <section class="section doctrine-section">
    <div class="container doctrine">
      <SectionHead
        eyebrow="Supply Doctrine" jp="信条" variant="cyan"
        title="Every patch is a small flag."
      />
      <div class="grid grid-3 mt-6">
        <div class="panel doctrine-card">
          <span class="d-icon"><Icon name="shield" size={22} /></span>
          <h3 class="h3">Built to survive</h3>
          <p class="muted">If it wouldn't make it through a real week in the field, it doesn't ship. That's the whole design brief.</p>
        </div>
        <div class="panel doctrine-card">
          <span class="d-icon"><Icon name="crosshair" size={22} /></span>
          <h3 class="h3">Limited on purpose</h3>
          <p class="muted">Small runs, real scarcity. When a colorway's gone it's usually gone for good — no restock treadmill.</p>
        </div>
        <div class="panel doctrine-card">
          <span class="d-icon"><Icon name="users" size={22} /></span>
          <h3 class="h3">A signal to your own</h3>
          <p class="muted">You see it across a room and you already know something true about the person wearing it. Worth more than the cotton.</p>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Move while it's in stock."
    text="Restocks are rare and drops are small. Get on the channels so you hear about the next one before the resellers do."
  />
</BaseLayout>

<style>
  .drop-band {
    position: relative;
    overflow: hidden;
    border-block: 1px solid var(--line);
    background:
      radial-gradient(600px 300px at 15% 0%, rgba(34, 224, 255, 0.1), transparent 60%),
      var(--void-2);
  }
  .drop-inner {
    position: relative; z-index: 3;
    display: flex; align-items: center; justify-content: space-between; gap: 2rem;
  }
  .drop-copy { max-width: 40ch; }
  .drop-glyph {
    font-size: clamp(4rem, 14vw, 9rem);
    color: rgba(238, 241, 248, 0.1);
    text-shadow: 0 0 40px rgba(34, 224, 255, 0.3);
    line-height: 1;
    flex: none;
  }
  @media (max-width: 700px) { .drop-glyph { display: none; } }

  .supply-note {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-size: 0.75rem; letter-spacing: 0.06em; color: var(--dim);
  }
  .supply-note :global(svg) { color: var(--amber); flex: none; }

  .doctrine-section { border-top: 1px solid var(--line); background: var(--void-2); }
  .doctrine-card { display: flex; flex-direction: column; gap: 0.6rem; }
  .d-icon {
    display: grid; place-items: center; width: 3rem; height: 3rem;
    color: var(--cyan);
    border: 1px solid rgba(34, 224, 255, 0.35);
    background: rgba(34, 224, 255, 0.06);
    margin-bottom: 0.4rem;
  }
  .doctrine-card .muted { font-size: 0.94rem; }
</style>
