---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Marquee from "../../components/Marquee.astro";
import Icon from "../../components/Icon.astro";
import { site, dispatches } from "../../data/site";
import { breadcrumbSchema, articleSchema } from "../../lib/schema";

export function getStaticPaths() {
  return dispatches.map((d) => ({ params: { slug: d.slug }, props: { dispatch: d } }));
}

const { dispatch: d } = Astro.props;
const idx = dispatches.findIndex((x) => x.slug === d.slug);
const next = dispatches[(idx + 1) % dispatches.length];

const title = `${d.title} — Dispatch | ${site.short}`;
const url = `/dispatches/${d.slug}/`;
const date = new Date(d.date + "T00:00:00Z").toLocaleDateString("en-US", {
  year: "numeric", month: "long", day: "numeric", timeZone: "UTC",
});
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Dispatches", url: "/dispatches/" },
  { name: d.title, url },
];
const schema = [
  breadcrumbSchema(crumbs),
  articleSchema({ title: d.title, description: d.excerpt, url, datePublished: d.date }),
];
---

<BaseLayout title={title} description={d.excerpt} canonical={url} schema={schema}>
  <article>
    <!-- Article header -->
    <header class="article-hero scanlines">
      <div class="grid-floor"></div>
      <div class="container container-narrow article-hero-inner">
        <Breadcrumbs crumbs={crumbs} />
        <div class="art-tags mono">
          <span class="tag is-red">{d.tag}</span>
          <span class="art-class">CLASSIFICATION // {d.classification}</span>
        </div>
        <h1 class="h1 display glitch art-title" data-text={d.title}>{d.title}</h1>
        <div class="art-meta mono">
          <span class="art-loc"><Icon name="pin" size={14} /> {d.location}</span>
          <span class="dot">·</span>
          <span><Icon name="calendar" size={14} /> {date}</span>
          <span class="dot">·</span>
          <span><Icon name="clock" size={14} /> {d.readTime}</span>
        </div>
      </div>
      <Marquee />
    </header>

    <!-- Body -->
    <div class="section">
      <div class="container container-narrow prose">
        <p class="begin mono">// BEGIN TRANSMISSION</p>
        {d.body.map((p, i) => (
          <p class:list={["art-p", { lead: i === 0 }]}>{p}</p>
        ))}
        <p class="end mono">// END TRANSMISSION — <span class="text-amber">{site.mottoJp}</span></p>
      </div>
    </div>

    <!-- Footer nav -->
    <section class="section-tight art-foot scanlines">
      <div class="container art-foot-inner">
        <a href="/dispatches/" class="link-arrow"><Icon name="arrow" size={16} class="flip" /> All Dispatches</a>
        <a href={`/dispatches/${next.slug}/`} class="next-card panel panel-hover is-red">
          <span class="next-label mono">NEXT DISPATCH //</span>
          <span class="next-title">{next.title}</span>
          <span class="next-arrow"><Icon name="arrow" size={20} /></span>
        </a>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .article-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(700px 340px at 25% 0%, rgba(255, 35, 64, 0.12), transparent 60%),
      var(--void);
  }
  .article-hero-inner { position: relative; z-index: 3; padding-block: clamp(2.4rem, 6vw, 4rem) clamp(1.6rem, 4vw, 2.5rem); }
  .art-tags { display: flex; align-items: center; gap: 0.9rem; }
  .art-class { font-size: 0.66rem; letter-spacing: 0.16em; color: var(--dim); text-transform: uppercase; }
  .art-title { margin-top: 1rem; max-width: 22ch; }
  .art-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
    margin-top: 1.4rem; font-size: 0.72rem; letter-spacing: 0.08em;
    text-transform: uppercase; color: var(--muted);
  }
  .art-loc { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--amber); }
  .art-meta span { display: inline-flex; align-items: center; gap: 0.35rem; }
  .art-meta .dot { opacity: 0.4; }

  .prose { color: var(--body); }
  .begin, .end {
    color: var(--red); font-size: 0.72rem; letter-spacing: 0.16em;
    padding: 0.5rem 0; border-block: 1px solid var(--line); margin: 0;
  }
  .end { margin-top: 1.5rem; color: var(--dim); }
  .art-p { margin-top: 1.4rem; font-size: 1.08rem; line-height: 1.8; }
  .art-p.lead {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 500;
    line-height: 1.5;
    color: var(--ink);
    margin-top: 1.6rem;
  }

  .art-foot { border-top: 1px solid var(--line); background: var(--void-2); }
  .art-foot-inner {
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  :global(.link-arrow .flip) { transform: rotate(180deg); }
  .next-card {
    display: flex; align-items: center; gap: 1rem;
    min-width: min(420px, 100%);
    text-decoration: none;
  }
  .next-label { color: var(--red); font-size: 0.68rem; letter-spacing: 0.14em; }
  .next-title { font-family: var(--font-display); font-weight: 600; color: var(--ink); flex: 1; }
  .next-arrow { color: var(--red); }
</style>
