---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import DispatchCard from "../../components/DispatchCard.astro";
import CtaBand from "../../components/CtaBand.astro";
import { site, dispatches } from "../../data/site";
import { breadcrumbSchema } from "../../lib/schema";

const title = `Dispatches — Field Notes from the Grey Zone | ${site.short}`;
const description =
  "Field notes and signal-war essays from forward of the line. Some recovered from channels that no longer exist.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Dispatches", url: "/dispatches/" },
];
const schema = [breadcrumbSchema(crumbs)];
const [featured, ...rest] = dispatches;
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="Dispatches" jp="通信" variant="amber"
    title="Dispatches"
    lead="Field notes, observation logs, and signal-war essays from forward of the line. Filed as we saw it — some of it recovered from channels that don't exist anymore."
    crumbs={crumbs}
  />

  <section class="section">
    <div class="container">
      <div class="dispatch-feature">
        <DispatchCard dispatch={featured} featured />
      </div>
      <div class="grid grid-3 mt-6">
        {rest.map((d) => <DispatchCard dispatch={d} />)}
      </div>
    </div>
  </section>

  <CtaBand
    heading="The record survives the takedown."
    text="Every dispatch is mirrored in the Vault. Follow the channels, and keep a copy of anything that matters to you."
  />
</BaseLayout>

<style>
  .dispatch-feature { max-width: 940px; }
</style>
