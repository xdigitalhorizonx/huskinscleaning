---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import Stars from "../components/Stars.astro";
import CtaBand from "../components/CtaBand.astro";
import { site, testimonials } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Reviews", url: "/reviews/" },
];
const title = "Reviews & Testimonials | Huskins Cleaning Omaha, NE";
const description =
  "See why Omaha homeowners and businesses rate Huskins Cleaning 5 stars. Read real customer reviews and testimonials, then get your own free quote today.";
---

<BaseLayout title={title} description={description} canonical="/reviews/" schema={[breadcrumbSchema(crumbs)]}>
  <PageHero
    eyebrow="Testimonials"
    title="Trusted by Omaha, review after review"
    text="Our reputation is built one spotless home at a time. Here's what our neighbors have to say about working with the Huskins team."
    crumbs={crumbs}
    showCta={false}
  />

  <section class="section-tight">
    <div class="container">
      <div class="rating-summary card">
        <div class="rs-score">
          <span class="rs-num">{site.rating.value}</span>
          <Stars />
          <span class="rs-count">{site.rating.count}+ reviews</span>
        </div>
        <div class="rs-copy">
          <h2 class="h3">A reputation we don't take for granted</h2>
          <p class="muted mt-1">
            From recurring house cleaning to move-outs and offices, our clients
            keep coming back — and keep sending their neighbors. That word-of-mouth
            trust is the highest compliment we can earn.
          </p>
          <div class="rs-badges mt-2">
            <span class="badge"><Icon name="award" size={15} /> BBB {site.bbb.rating} Accredited</span>
            <span class="badge"><Icon name="shield" size={15} /> Insured</span>
            <span class="badge"><Icon name="heart" size={15} /> Locally Loved</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="padding-top:0">
    <div class="container">
      <div class="reviews-grid">
        {testimonials.map((t) => (
          <figure class="card review-full">
            <Stars />
            <blockquote>“{t.quote}”</blockquote>
            <figcaption>
              <span class="rf-avatar">{t.author.charAt(0)}</span>
              <span>
                <strong>{t.author}</strong>
                <small>{t.location} · {t.service}</small>
              </span>
            </figcaption>
          </figure>
        ))}
      </div>

      <div class="reviews-invite card">
        <Icon name="sparkles" size={28} />
        <div>
          <h2 class="h3">Been cleaned by Huskins?</h2>
          <p class="muted">We'd be grateful for your feedback — and it helps other Omaha neighbors find a team they can trust.</p>
        </div>
        <a href={site.phone.href} class="btn btn-ghost">Share Your Experience</a>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Join hundreds of happy Omaha customers"
    text="See the difference an honest, detail-obsessed team makes. Your free quote is only a click away."
  />
</BaseLayout>

<style>
  .rating-summary {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.4rem, 4vw, 3rem);
    align-items: center;
    background: linear-gradient(135deg, var(--brand-50), var(--surface));
    border-color: var(--brand-200);
  }
  .rs-score {
    display: grid;
    justify-items: center;
    gap: 0.3rem;
    padding-right: clamp(1.4rem, 4vw, 3rem);
    border-right: 1px solid var(--line);
    text-align: center;
  }
  .rs-num {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 3.4rem;
    line-height: 1;
    color: var(--brand-700);
  }
  .rs-count { font-size: 0.85rem; color: var(--muted); }
  .rs-badges { display: flex; flex-wrap: wrap; gap: 0.5rem; }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.4rem;
  }
  .review-full { display: flex; flex-direction: column; gap: 1rem; }
  .review-full blockquote {
    margin: 0;
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--ink);
    flex: 1;
  }
  .review-full figcaption { display: flex; align-items: center; gap: 0.8rem; }
  .rf-avatar {
    display: grid;
    place-items: center;
    width: 2.8rem;
    height: 2.8rem;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--brand-400), var(--brand-700));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    flex: none;
  }
  .review-full strong { display: block; color: var(--ink); font-family: var(--font-display); }
  .review-full small { color: var(--muted); font-size: 0.82rem; }

  .reviews-invite {
    margin-top: 1.6rem;
    display: flex;
    align-items: center;
    gap: 1.2rem;
    background: var(--brand-ink);
    color: #d6e6f7;
    border: none;
  }
  .reviews-invite :global(svg) { color: var(--accent); flex: none; }
  .reviews-invite h3 { color: #fff; }
  .reviews-invite .muted { color: #a6c3e2; }
  .reviews-invite .btn { margin-left: auto; flex: none; --btn-fg: #fff; border-color: rgba(255,255,255,.35); }
  .reviews-invite .btn:hover { background: rgba(255,255,255,.1); --btn-fg:#fff; }

  @media (max-width: 720px) {
    .rating-summary { grid-template-columns: 1fr; }
    .rs-score { border-right: none; border-bottom: 1px solid var(--line); padding-right: 0; padding-bottom: 1.2rem; }
    .reviews-grid { grid-template-columns: 1fr; }
    .reviews-invite { flex-direction: column; text-align: center; }
    .reviews-invite .btn { margin-left: 0; }
  }
</style>
