---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import ServiceCard from "../components/ServiceCard.astro";
import Faq from "../components/Faq.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, services, process, faqs } from "../data/site";
import { breadcrumbSchema, faqSchema } from "../lib/schema";

const title = `Services — Web Design, SEO & Digital Marketing | ${site.brand}`;
const description =
  "Custom web design, local SEO, and digital marketing for Northern Nevada service businesses. Three disciplines, built to work as one system.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Services", url: "/services/" },
];
const schema = [breadcrumbSchema(crumbs), faqSchema(faqs)];
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="Services" variant="red"
    title="Three disciplines. One horizon."
    lead="We don't sell channels — we build a system. Web design that ranks, SEO that compounds, and digital marketing that brings the right customers to your door."
    crumbs={crumbs}
  />

  <section class="section">
    <div class="container">
      <div class="grid grid-3">
        {services.map((s) => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section process-section scanlines">
    <div class="container">
      <SectionHead
        eyebrow="How we work" variant="amber"
        title="Project to partnership."
        lead="Start with one well-scoped project at a fixed price. No retainer on day one, no surprises — and if the monthly partnership doesn't pay for itself by month three, we'll tell you so."
      />
      <div class="grid grid-4 mt-6 process-grid">
        {process.map((step) => (
          <div class="panel process-card">
            <span class="ps-num mono">{step.num}</span>
            <h3 class="h3 ps-title">{step.title}</h3>
            <p class="muted ps-text">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- One system -->
  <section class="section">
    <div class="container onesystem panel is-cyan">
      <div>
        <SectionHead
          eyebrow="Why it works" variant="cyan"
          title="One system, not three invoices."
        />
        <p class="lead mt-2">
          A great website with no traffic is a brochure. Traffic with a slow, confusing
          site is a leaky bucket. We build web, SEO, and marketing to reinforce each
          other — so the whole thing compounds instead of competing for budget.
        </p>
      </div>
      <ul class="intel-list onesystem-list">
        <li><b class="text-ink">Web feeds SEO.</b> Fast, well-structured pages are what Google can actually rank.</li>
        <li><b class="text-ink">SEO feeds marketing.</b> Owned rankings lower what every paid click has to earn.</li>
        <li><b class="text-ink">Marketing feeds the site.</b> Real campaign data tells us what to build and fix next.</li>
        <li><b class="text-ink">All of it feeds you.</b> More qualified calls, from the customers you actually want.</li>
      </ul>
    </div>
  </section>

  <Faq items={faqs} />

  <CtaBand />
</BaseLayout>

<style>
  .process-section { background: var(--void-2); border-block: 1px solid var(--line); }
  .process-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .ps-num { font-family: var(--font-num); font-size: 1.3rem; color: var(--amber); }
  .ps-title { font-size: 1.2rem; }
  .ps-text { font-size: 0.92rem; }
  @media (max-width: 980px) { .process-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .process-grid { grid-template-columns: 1fr; } }

  .onesystem {
    display: grid; grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(1.5rem, 4vw, 3rem); align-items: center;
  }
  .onesystem-list { font-size: 1rem; gap: 0.9rem; }
  @media (max-width: 820px) { .onesystem { grid-template-columns: 1fr; } }
</style>
