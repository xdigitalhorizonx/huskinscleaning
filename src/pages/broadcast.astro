---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import ShowCard from "../components/ShowCard.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, shows, episodes } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const title = `Broadcast — Channels & Transmissions | ${site.short}`;
const description =
  "The Forward Observations broadcast network: long-form radio, field documentary, recovered Vault uploads, and after-dark livestreams. Watch and listen everywhere.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "Broadcast", url: "/broadcast/" },
];
const schema = [breadcrumbSchema(crumbs)];
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="Broadcast" jp="放送" variant="red"
    title="Broadcast"
    lead="Four channels, one signal. Wherever it lands — audio, video, livestream, or a mirror of something they already deleted — it's the same voice from the same edge."
    crumbs={crumbs}
  />

  <!-- Channels -->
  <section class="section">
    <div class="container">
      <SectionHead eyebrow="The Channels" jp="回線" variant="amber" title="Pick your frequency" />
      <div class="grid grid-4 mt-6">
        {shows.map((s) => <ShowCard show={s} />)}
      </div>
    </div>
  </section>

  <!-- Transmission log -->
  <section class="section transmissions scanlines">
    <div class="container">
      <div class="sec-top">
        <SectionHead eyebrow="Transmission Log" jp="実況" variant="cyan" title="Every recent drop" />
        <a href={site.social.spotify} target="_blank" rel="noopener" class="btn btn-ghost sec-top-cta">
          <Icon name="headphones" size={16} /> Subscribe
        </a>
      </div>
      <div class="ep-list mt-6">
        {episodes.map((e) => (
          <a href={site.social.youtube} target="_blank" rel="noopener" class="ep-row">
            <span class="ep-play"><Icon name="play" size={16} /></span>
            <span class="ep-num mono">{e.ep}</span>
            <span class="ep-main">
              <span class="ep-title">{e.title}</span>
              <span class="ep-desc">{e.desc}</span>
              <span class="ep-show mono">{e.show}</span>
            </span>
            <span class="tag is-red ep-tag">{e.tag}</span>
            <span class="ep-dur mono">{e.duration}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading="Subscribe before the next takedown."
    text="Follow every channel and mirror what matters. The Vault keeps the record — but nothing beats catching it live."
  />
</BaseLayout>

<style>
  .sec-top {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .sec-top .section-head { flex: 1; min-width: 280px; }
  .sec-top-cta { flex: none; }

  .transmissions {
    background:
      radial-gradient(600px 300px at 100% 0%, rgba(34, 224, 255, 0.06), transparent 60%),
      var(--void-2);
    border-block: 1px solid var(--line);
  }
  .ep-list { display: grid; gap: 0.4rem; }
  .ep-row {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--body);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s var(--ease);
  }
  .ep-row:hover {
    border-color: rgba(34, 224, 255, 0.4);
    background: var(--surface-2);
    transform: translateX(4px);
  }
  .ep-play {
    display: grid; place-items: center;
    width: 2.2rem; height: 2.2rem; flex: none;
    color: var(--red);
    border: 1px solid rgba(255, 35, 64, 0.4);
    background: rgba(255, 35, 64, 0.08);
    border-radius: 50%;
  }
  .ep-row:hover .ep-play { color: #fff; background: var(--red); }
  .ep-num { color: var(--amber); font-size: 0.8rem; min-width: 3.4rem; }
  .ep-main { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .ep-title { font-family: var(--font-display); font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .ep-desc {
    color: var(--muted); font-size: 0.85rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .ep-show { color: var(--dim); font-size: 0.68rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.1rem; }
  .ep-dur { color: var(--dim); font-size: 0.8rem; }
  @media (max-width: 700px) {
    .ep-row { grid-template-columns: auto 1fr auto; }
    .ep-num, .ep-desc { display: none; }
  }
</style>
