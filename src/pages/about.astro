---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import SectionHead from "../components/SectionHead.astro";
import Faq from "../components/Faq.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, values, industries, faqs } from "../data/site";
import { breadcrumbSchema, faqSchema } from "../lib/schema";

const title = `About — ${site.brand} | Northern Nevada Web & Marketing`;
const description =
  "Digital Horizon is a Carson City team building websites, SEO, and marketing systems for Northern Nevada service and trade businesses — local knowledge, fixed scope, real results.";
const crumbs = [
  { name: "Home", url: "/" },
  { name: "About", url: "/about/" },
];
const schema = [breadcrumbSchema(crumbs), faqSchema(faqs)];
---

<BaseLayout title={title} description={description} schema={schema}>
  <PageHero
    eyebrow="About" variant="amber"
    title="Systems, not brochures."
    lead="Digital Horizon is a Carson City team that builds websites, SEO, and marketing that actually bring Northern Nevada businesses more of the work they want."
    crumbs={crumbs}
  />

  <!-- Story + studio card -->
  <section class="section">
    <div class="container story">
      <div class="story-copy">
        <SectionHead
          eyebrow="Who we are" variant="red"
          title="Local, plain-spoken, and allergic to fluff."
        />
        <div class="flow mt-3">
          <p class="lead">
            A pretty website nobody finds and nobody books from is a very expensive
            brochure. We build the opposite: sites that load fast, rank on Google,
            and turn visitors into booked work — backed by SEO and marketing that
            compound month over month.
          </p>
          <p>
            We're based in Carson City and we build for the businesses that keep
            Northern Nevada running — the plumbers, roofers, landscapers, shops, and
            offices from Reno to Tahoe. Local knowledge is a real advantage: we know
            the seasons, the competition, and the search terms your customers
            actually type.
          </p>
          <p>
            We're not an agency that disappears after launch or hides the ball behind
            jargon. We start with one well-scoped project, we show you the data, and
            we earn the monthly partnership by making the numbers move.
          </p>
        </div>
      </div>

      <aside class="studio panel is-cyan mono">
        <div class="studio-head">
          <span><span class="status-dot"></span> STUDIO PROFILE</span>
        </div>
        <dl>
          <div><dt>BASED IN</dt><dd class="text-cyan">Carson City, NV</dd></div>
          <div><dt>SERVES</dt><dd>Northern Nevada</dd></div>
          <div><dt>DISCIPLINES</dt><dd>WEB · SEO · MARKETING</dd></div>
          <div><dt>ENGAGEMENT</dt><dd>FIXED SCOPE → PARTNERSHIP</dd></div>
          <div><dt>STATUS</dt><dd class="text-lime">● NOW BOOKING</dd></div>
          <div><dt>MOTTO</dt><dd class="text-amber">ONE HORIZON</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <!-- Pull quote -->
  <section class="section-tight quote-band scanlines">
    <div class="grid-floor"></div>
    <div class="container container-narrow text-center">
      <p class="pull-quote display">
        “We don't sell channels — we build a <span class="text-amber">system.</span>”
      </p>
      <p class="pull-attr mono mt-2">— HOW DIGITAL HORIZON WORKS</p>
    </div>
  </section>

  <!-- Values -->
  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="What you can count on" variant="amber"
        title="Four things we don't compromise on" center
      />
      <div class="grid grid-4 mt-6">
        {values.map((v) => (
          <div class="panel value-card">
            <span class="v-icon"><Icon name={v.icon} size={22} /></span>
            <h3 class="h3">{v.title}</h3>
            <p class="muted">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section class="section industries-section scanlines">
    <div class="container">
      <SectionHead
        eyebrow="Who we build for" variant="cyan"
        title="Built for the businesses that keep Northern Nevada running" center
      />
      <div class="industry-cloud mt-6">
        {industries.map((i) => <span class="industry-chip">{i}</span>)}
      </div>
    </div>
  </section>

  <Faq items={faqs} />

  <CtaBand />
</BaseLayout>

<style>
  .story {
    display: grid; grid-template-columns: 1.4fr 0.9fr;
    gap: clamp(1.5rem, 5vw, 3.5rem); align-items: start;
  }
  @media (max-width: 900px) { .story { grid-template-columns: 1fr; } }

  .studio { font-size: 0.78rem; }
  .studio-head {
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
    padding-bottom: 0.8rem; margin-bottom: 0.8rem; border-bottom: 1px solid var(--line);
  }
  .studio dl { display: grid; gap: 0.7rem; margin: 0; }
  .studio dl > div {
    display: grid; grid-template-columns: 8rem 1fr; gap: 0.6rem;
    padding-bottom: 0.6rem; border-bottom: 1px dashed var(--line);
  }
  .studio dt { color: var(--dim); letter-spacing: 0.1em; }
  .studio dd { margin: 0; color: var(--ink); }
  .text-lime { color: var(--lime); }
  .text-cyan { color: var(--cyan); }

  .quote-band {
    position: relative; overflow: hidden;
    border-block: 1px solid var(--line);
    background: radial-gradient(600px 300px at 50% 0%, rgba(232, 92, 151, 0.1), transparent 60%), var(--void-2);
  }
  .quote-band > .container { position: relative; z-index: 3; }
  .pull-quote {
    font-size: clamp(1.6rem, 1rem + 3vw, 3rem);
    line-height: 1.2; color: var(--ink); text-wrap: balance;
  }
  .pull-attr { color: var(--muted); letter-spacing: 0.16em; font-size: 0.72rem; }

  .value-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .v-icon {
    display: grid; place-items: center; width: 3rem; height: 3rem;
    color: var(--amber);
    border: 1px solid rgba(79, 147, 218, 0.35);
    background: rgba(79, 147, 218, 0.06);
    margin-bottom: 0.3rem;
  }
  .value-card .muted { font-size: 0.92rem; }

  .industries-section { background: var(--void-2); border-top: 1px solid var(--line); }
  .industry-cloud { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; }
  .industry-chip {
    padding: 0.5rem 0.9rem; border: 1px solid var(--line); background: var(--surface);
    color: var(--body); font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.04em;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s var(--ease);
  }
  .industry-chip:hover { border-color: var(--cyan); color: var(--ink); transform: translateY(-2px); }
</style>
