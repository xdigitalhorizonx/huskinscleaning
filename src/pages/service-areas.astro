---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import CtaBand from "../components/CtaBand.astro";
import { services, serviceAreas } from "../data/site";
import { breadcrumbSchema } from "../lib/schema";

const crumbs = [
  { name: "Home", url: "/" },
  { name: "Service Areas", url: "/service-areas/" },
];
const title = "Cleaning Service Areas | Omaha Metro | Huskins Cleaning";
const description =
  "Huskins Cleaning serves Omaha and the surrounding metro — Bellevue, Papillion, La Vista, Elkhorn, Bennington, Gretna, Ralston & Council Bluffs. See if we clean your area.";
---

<BaseLayout title={title} description={description} canonical="/service-areas/" schema={[breadcrumbSchema(crumbs)]}>
  <PageHero
    eyebrow="Where We Clean"
    title="Serving Omaha & the surrounding communities"
    text="Huskins is a homegrown Omaha company, and we're proud to bring dependable, high-quality cleaning to neighborhoods and businesses right across the metro area."
    crumbs={crumbs}
    image="/images/exterior.webp"
    imageAlt="A well-kept suburban home in the greater Omaha area"
  />

  <section class="section">
    <div class="container">
      <div class="section-head is-center">
        <span class="eyebrow">Local Coverage</span>
        <h2 class="h2">Communities we proudly serve</h2>
        <p class="lead">Don't see your town? Give us a call — if you're near Omaha, there's a good chance we can help.</p>
      </div>
      <div class="grid grid-3 mt-6">
        {serviceAreas.map((a) => (
          <div class="card area-card">
            <span class="area-icon"><Icon name="pin" size={22} /></span>
            <div>
              <h3>{a.name}</h3>
              <p>{a.note ?? "Residential & commercial cleaning available"}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section areas-services">
    <div class="container">
      <div class="areas-services-inner">
        <div>
          <span class="eyebrow">Available Everywhere We Serve</span>
          <h2 class="h2">Every service, across the whole metro</h2>
          <p class="lead mt-1">
            No matter which community you're in, you get the full range of
            Huskins services and the same trusted, insured crew.
          </p>
          <a href="/contact/" class="btn btn-primary mt-3">Check Availability</a>
        </div>
        <ul class="areas-service-list">
          {services.map((s) => (
            <li>
              <a href={`/services/${s.slug}/`}>
                <Icon name={s.icon} size={20} />
                <span>{s.title}</span>
                <Icon name="arrow" size={16} class="asl-arrow" />
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <section class="section-tight">
    <div class="container">
      <div class="areas-map">
        <iframe
          title="Huskins Cleaning service area map — Greater Omaha"
          src="https://maps.google.com/maps?q=Omaha%2C%20NE&z=10&output=embed"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  </section>

  <CtaBand
    heading="Serving your Omaha neighborhood"
    text="Get a fast, free quote and see why so many of your neighbors trust Huskins with their homes and businesses."
  />
</BaseLayout>

<style>
  .area-card { display: flex; align-items: center; gap: 1rem; }
  .area-icon {
    display: grid;
    place-items: center;
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--brand-50);
    color: var(--brand-700);
    border: 1px solid var(--brand-100);
    flex: none;
  }
  .area-card h3 { font-size: 1.15rem; color: var(--ink); }
  .area-card p { font-size: 0.88rem; color: var(--muted); }

  .areas-services { background: var(--surface-2); }
  .areas-services-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.6rem, 5vw, 3.5rem);
    align-items: center;
  }
  .areas-service-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.6rem; }
  .areas-service-list a {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 0.9rem 1.2rem;
    font-family: var(--font-display);
    font-weight: 700;
    color: var(--ink);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .areas-service-list a:hover { border-color: var(--brand-300); transform: translateX(4px); }
  .areas-service-list :global(svg):first-child { color: var(--brand-600); flex: none; }
  .areas-service-list :global(.asl-arrow) { margin-left: auto; color: var(--brand-400); }

  .areas-map {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
  }
  .areas-map iframe { width: 100%; height: 360px; border: 0; display: block; }

  @media (max-width: 820px) {
    .areas-services-inner { grid-template-columns: 1fr; }
  }
</style>
