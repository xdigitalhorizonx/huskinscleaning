---
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
import SectionHead from "../components/SectionHead.astro";
import ServiceCard from "../components/ServiceCard.astro";
import PostCard from "../components/PostCard.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, stats, kpis, services, process, testimonials, industries, posts } from "../data/site";
import { faqSchema } from "../lib/schema";

const title = `${site.brand} — Web Design, SEO & Digital Marketing in Northern Nevada`;
const description = site.description;
const latestPosts = posts.slice(0, 3);
const bars = [42, 55, 48, 63, 71, 66, 82, 95];
const schema = [faqSchema()];
---

<BaseLayout title={title} description={description} schema={schema}>
  <!-- ===== HERO ===== -->
  <section class="hero scanlines">
    <div class="grid-floor"></div>
    <div class="hero-bloom" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow is-red">
          <span class="status-dot"></span> Web Design + Local SEO
        </span>
        <h1 class="hero-title display">
          Web design that brings <span class="text-amber">Northern Nevada</span> customers in.
        </h1>
        <p class="hero-lead lead">
          {site.brand} builds custom websites for Northern Nevada service businesses —
          fast on mobile, ready to rank on Google, and built to turn visits into booked work.
        </p>
        <div class="btn-group hero-cta">
          <a href="/contact/" class="btn btn-primary btn-lg"><Icon name="rocket" size={18} /> Start a Project</a>
          <a href="/services/" class="btn btn-ghost btn-lg"><Icon name="compass" size={18} /> See Our Services</a>
        </div>
        <div class="hero-channels mono">
          <span class="dim">TRUSTED BY TRADES ACROSS //</span>
          Reno<span class="sep">·</span>Sparks<span class="sep">·</span>Carson City<span class="sep">·</span>Tahoe
        </div>
      </div>

      <!-- Analytics console -->
      <div class="console panel is-cyan" aria-hidden="true">
        <div class="console-head mono">
          <span><span class="status-dot"></span> LIVE VISIBILITY</span>
          <span class="text-amber">Search Console · Analytics</span>
        </div>
        <div class="kpi-grid">
          {kpis.map((k) => (
            <div class="kpi">
              <span class="kpi-val">{k.value}</span>
              <span class="kpi-label">{k.label}</span>
              <span class:list={["kpi-delta", k.tone === "up" ? "is-up" : ""]}>{k.delta}</span>
            </div>
          ))}
        </div>
        <div class="chart">
          <div class="chart-head mono"><span>ORGANIC CLICKS</span><span class="text-cyan">LAST 28 DAYS ▲</span></div>
          <div class="bars">
            {bars.map((h, i) => (
              <span class="bar" style={`--h:${h}%;--d:${i * 0.08}s`}></span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <Marquee />

  <!-- ===== STATS ===== -->
  <section class="section-tight stats-band">
    <div class="container">
      <div class="grid grid-4 stats-grid">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-num">{s.num}</div>
            <div class="stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES ===== -->
  <section class="section">
    <div class="container">
      <div class="sec-top">
        <SectionHead
          eyebrow="What we do" variant="red"
          title="Three disciplines. <span class='text-amber'>One horizon.</span>"
          lead="We don't sell channels — we build a system. Web design that ranks, SEO that compounds, and digital marketing that brings the right customers to your door."
        />
        <a href="/services/" class="btn btn-ghost sec-top-cta">All Services <Icon name="arrow" size={16} /></a>
      </div>
      <div class="grid grid-3 mt-6">
        {services.map((s) => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="section process-section scanlines">
    <div class="container">
      <SectionHead
        eyebrow="How we work" variant="amber"
        title="Project to partnership."
        lead="We start with one well-scoped project so you can feel how we work without committing to a long contract. Most clients move into a monthly partnership within 90 days — because the cost-per-result keeps dropping."
      />
      <div class="grid grid-4 mt-6 process-grid">
        {process.map((step) => (
          <div class="panel process-card">
            <span class="ps-num mono">{step.num}</span>
            <h3 class="h3 ps-title">{step.title}</h3>
            <p class="ps-text muted">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== VISIBILITY ===== -->
  <section class="section">
    <div class="container visibility">
      <div class="vis-copy">
        <SectionHead
          eyebrow="Real-time visibility" variant="cyan"
          title="See what your website is <span class='text-cyan'>actually doing.</span>"
          lead="Real-time visibility into what's ranking, what's converting, and what to fix next — so every change you make is informed by actual data, not a hunch."
        />
        <a href="/contact/" class="link-arrow mt-3">Get your free visibility audit <Icon name="arrow" size={16} /></a>
      </div>
      <div class="vis-panel panel is-cyan">
        <div class="vis-head mono"><span>SEARCH CONSOLE</span><span class="dim">28 DAYS vs PREVIOUS</span></div>
        <div class="vis-metrics">
          <div><span class="vm-val">267K</span><span class="vm-label">Clicks <b class="up">+12.4%</b></span></div>
          <div><span class="vm-val">6.82M</span><span class="vm-label">Impressions <b class="up">+4.1%</b></span></div>
          <div><span class="vm-val">3.92%</span><span class="vm-label">Avg CTR</span></div>
          <div><span class="vm-val">3.2</span><span class="vm-label">Avg Position <b class="up">▲</b></span></div>
        </div>
        <div class="rank-dist mono">
          <div class="rd-row"><span>TOP 3</span><span class="rd-bar"><i style="--w:33%"></i></span><span>33.1%</span></div>
          <div class="rd-row"><span>4–10</span><span class="rd-bar"><i style="--w:42%"></i></span><span>42.1%</span></div>
          <div class="rd-row"><span>11–20</span><span class="rd-bar"><i style="--w:22%"></i></span><span>22.0%</span></div>
          <div class="rd-row"><span>21–50</span><span class="rd-bar"><i style="--w:3%"></i></span><span>2.8%</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS ===== -->
  <section class="section testi-section scanlines">
    <div class="container">
      <SectionHead eyebrow="Client success" variant="red" title="What clients say" center />
      <div class="grid grid-2 mt-6">
        {testimonials.map((t) => (
          <figure class="panel testi-card">
            <Icon name="quote" size={26} class="testi-mark" />
            <blockquote class="testi-quote">{t.quote}</blockquote>
            <figcaption class="testi-by">
              <span class="testi-author">{t.author}</span>
              <span class="testi-co mono">{t.company}{t.location ? ` · ${t.location}` : ""}{t.date ? ` · ${t.date}` : ""}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== INDUSTRIES ===== -->
  <section class="section">
    <div class="container">
      <SectionHead
        eyebrow="Who we build for" variant="amber"
        title="Built for the businesses that keep Northern Nevada running" center
      />
      <div class="industry-cloud mt-6">
        {industries.map((i) => <span class="industry-chip">{i}</span>)}
      </div>
    </div>
  </section>

  <!-- ===== BLOG ===== -->
  <section class="section blog-preview scanlines">
    <div class="container">
      <div class="sec-top">
        <SectionHead eyebrow="Field notes" variant="cyan" title="From the journal"
          lead="Working notes on SEO, web performance, and the software we build for Northern Nevada service businesses." />
        <a href="/blog/" class="btn btn-ghost sec-top-cta">All Articles <Icon name="arrow" size={16} /></a>
      </div>
      <div class="grid grid-3 mt-6">
        {latestPosts.map((p) => <PostCard post={p} />)}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(820px 420px at 12% -5%, rgba(255, 90, 60, 0.16), transparent 60%),
      radial-gradient(760px 500px at 105% 10%, rgba(34, 224, 255, 0.1), transparent 55%),
      var(--void);
  }
  .hero-bloom {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(900px 500px at 60% 120%, rgba(255, 157, 0, 0.12), transparent 60%);
  }
  .hero-grid {
    position: relative; z-index: 3;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .hero-title {
    font-size: var(--step-5);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 1.1rem 0 0;
    max-width: 16ch;
  }
  .hero-lead { margin-top: 1.4rem; max-width: 52ch; }
  .hero-cta { margin-top: 2rem; }
  .hero-channels {
    margin-top: 1.6rem;
    display: flex; flex-wrap: wrap; align-items: center; gap: 0.4rem;
    font-size: 0.76rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--body);
  }
  .hero-channels .sep { color: var(--red); opacity: 0.6; margin: 0 0.1rem; }

  /* Analytics console */
  .console { background: rgba(8, 10, 18, 0.7); }
  .console-head {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted);
    padding-bottom: 0.9rem; margin-bottom: 1rem; border-bottom: 1px solid var(--line);
  }
  .console-head .status-dot { display: inline-block; margin-right: 0.4rem; vertical-align: middle; }
  .kpi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.7rem; }
  .kpi {
    display: flex; flex-direction: column; gap: 0.1rem;
    padding: 0.8rem; border: 1px solid var(--line); background: var(--void-2);
  }
  .kpi-val { font-family: var(--font-num); font-weight: 700; font-size: 1.5rem; color: var(--ink); }
  .kpi-label { font-size: 0.66rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); font-family: var(--font-mono); }
  .kpi-delta { font-family: var(--font-mono); font-size: 0.66rem; color: var(--dim); margin-top: 0.15rem; }
  .kpi-delta.is-up { color: var(--lime); }

  .chart { margin-top: 1rem; }
  .chart-head { display: flex; justify-content: space-between; font-size: 0.62rem; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 0.5rem; }
  .bars { display: flex; align-items: flex-end; gap: 0.4rem; height: 70px; }
  .bar {
    flex: 1; height: var(--h); align-self: flex-end;
    background: linear-gradient(180deg, var(--cyan), rgba(34, 224, 255, 0.25));
    transform-origin: bottom; animation: bar-grow 0.7s var(--ease) both; animation-delay: var(--d);
  }
  @keyframes bar-grow { from { transform: scaleY(0); } }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .console { max-width: 460px; }
  }

  /* ===== Shared ===== */
  .sec-top {
    display: flex; align-items: flex-end; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .sec-top .section-head { flex: 1; min-width: 280px; }
  .sec-top-cta { flex: none; }

  .stats-band { border-bottom: 1px solid var(--line); background: var(--void-2); }
  .stats-grid { text-align: left; }
  .stat { padding: 0.5rem 0 0.5rem 1rem; border-left: 2px solid var(--red); }

  .process-section { background: var(--void-2); border-block: 1px solid var(--line); }
  .process-card { display: flex; flex-direction: column; gap: 0.5rem; }
  .ps-num { font-family: var(--font-num); font-size: 1.3rem; color: var(--amber); }
  .ps-title { font-size: 1.2rem; }
  .ps-text { font-size: 0.92rem; }
  @media (max-width: 980px) { .process-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .process-grid { grid-template-columns: 1fr; } }

  .visibility {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem); align-items: center;
  }
  @media (max-width: 900px) { .visibility { grid-template-columns: 1fr; } }
  .vis-head { display: flex; justify-content: space-between; font-size: 0.66rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); padding-bottom: 0.8rem; border-bottom: 1px solid var(--line); }
  .vis-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin: 1rem 0 1.2rem; }
  .vm-val { font-family: var(--font-num); font-weight: 700; font-size: 1.5rem; color: var(--ink); display: block; }
  .vm-label { font-size: 0.72rem; color: var(--muted); font-family: var(--font-mono); }
  .vm-label .up { color: var(--lime); }
  .rank-dist { display: grid; gap: 0.5rem; }
  .rd-row { display: grid; grid-template-columns: 3.5rem 1fr 3rem; align-items: center; gap: 0.7rem; font-size: 0.68rem; color: var(--muted); }
  .rd-bar { height: 7px; background: var(--void-2); border: 1px solid var(--line); position: relative; }
  .rd-bar i { position: absolute; inset: 0 auto 0 0; width: var(--w); background: linear-gradient(90deg, var(--amber), var(--red)); }

  .testi-section { background: var(--void-2); border-block: 1px solid var(--line); }
  .testi-card { display: flex; flex-direction: column; gap: 1rem; }
  .testi-card :global(.testi-mark) { color: var(--red); }
  .testi-quote { font-family: var(--font-display); font-size: 1.12rem; line-height: 1.5; color: var(--ink); font-weight: 500; }
  .testi-by { display: flex; flex-direction: column; gap: 0.2rem; margin-top: auto; }
  .testi-author { font-weight: 700; color: var(--ink); }
  .testi-co { font-size: 0.72rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--amber); }

  .industry-cloud { display: flex; flex-wrap: wrap; gap: 0.6rem; justify-content: center; }
  .industry-chip {
    padding: 0.5rem 0.9rem;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--body);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s var(--ease);
  }
  .industry-chip:hover { border-color: var(--cyan); color: #fff; transform: translateY(-2px); }

  .blog-preview { background: var(--void-2); border-block: 1px solid var(--line); }
</style>
