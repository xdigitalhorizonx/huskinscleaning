---
import BaseLayout from "../layouts/BaseLayout.astro";
import Marquee from "../components/Marquee.astro";
import SectionHead from "../components/SectionHead.astro";
import ShowCard from "../components/ShowCard.astro";
import DispatchCard from "../components/DispatchCard.astro";
import ProductCard from "../components/ProductCard.astro";
import CtaBand from "../components/CtaBand.astro";
import Icon from "../components/Icon.astro";
import { site, stats, shows, episodes, dispatches, products } from "../data/site";

const title = `${site.brand} — Eyes Forward of the Line`;
const description = site.description;
const latestEpisodes = episodes.slice(0, 4);
const featured = dispatches[0];
const moreDispatches = dispatches.slice(1, 4);
const supplyPreview = products.slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <!-- ===== HERO ===== -->
  <section class="hero scanlines">
    <div class="grid-floor"></div>
    <div class="hero-scan-bloom" aria-hidden="true"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow is-red">
          <span class="status-dot"></span> Veteran Media Collective
          <span class="jp">前線観測</span>
        </span>
        <h1 class="hero-title display glitch" data-text="Eyes Forward of the Line">
          Eyes <span class="text-red">Forward</span> of the Line
        </h1>
        <p class="hero-lead lead">
          <b class="text-ink">{site.brand}</b> broadcasts from the edge of the signal —
          field dispatches, long-form radio, and supply for the observant.
          They keep pulling the channel. We keep pushing it forward.
        </p>
        <div class="btn-group hero-cta">
          <a href="/broadcast/" class="btn btn-primary btn-lg"><Icon name="play" size={18} /> Watch Live</a>
          <a href="/dispatches/" class="btn btn-ghost btn-lg"><Icon name="terminal" size={18} /> Read Dispatches</a>
        </div>
        <div class="hero-channels mono">
          <span class="dim">ON THE NET //</span>
          <a href={site.social.youtube} target="_blank" rel="noopener">YouTube</a>
          <span class="sep">·</span>
          <a href={site.social.spotify} target="_blank" rel="noopener">Spotify</a>
          <span class="sep">·</span>
          <a href={site.social.instagram} target="_blank" rel="noopener">Instagram</a>
          <span class="sep">·</span>
          <a href={site.social.x} target="_blank" rel="noopener">X</a>
        </div>
      </div>

      <!-- Observation console -->
      <div class="console panel is-cyan" aria-hidden="true">
        <div class="console-head mono">
          <span><span class="status-dot"></span> OBSERVATION POST</span>
          <span class="text-amber jp">観測所</span>
        </div>
        <div class="radar">
          <div class="radar-rings"></div>
          <div class="radar-cross"></div>
          <div class="radar-sweep"></div>
          <span class="blip" style="--x:68%;--y:30%;--d:0s"></span>
          <span class="blip" style="--x:34%;--y:58%;--d:1.2s"></span>
          <span class="blip" style="--x:76%;--y:66%;--d:2.1s"></span>
          <span class="blip" style="--x:48%;--y:24%;--d:3s"></span>
        </div>
        <div class="console-readout mono">
          <div class="row"><span>TARGET</span><span class="text-cyan">ACQUIRED</span></div>
          <div class="row"><span>BEARING</span><span>142.7°</span></div>
          <div class="row"><span>RANGE</span><span>1.2 KM</span></div>
          <div class="row"><span>SIGNAL</span><span class="text-lime">● GREEN</span></div>
        </div>
      </div>
    </div>
  </section>

  <Marquee />

  <!-- ===== STATS ===== -->
  <section class="section-tight stats-band">
    <div class="container">
      <div class="grid grid-4 stats-grid">
        {stats.map((s) => (
          <div class="stat">
            <div class="stat-num">{s.num}</div>
            <div class="stat-label">{s.label} <span class="jp text-amber">{s.jp}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MANIFESTO ===== -->
  <section class="section">
    <div class="container manifesto">
      <div>
        <SectionHead
          eyebrow="Who We Are" jp="部隊" variant="amber"
          title="A forward observer <span class='text-red'>sees it first</span> — then tells the truth about it."
        />
        <p class="lead mt-3">
          That's the whole job. Get ahead of the line, watch clearly, report it exactly
          as it is. No anchor desk, no flattering edit — just the observation, and the
          discipline to call it in honestly.
        </p>
        <a href="/about/" class="link-arrow mt-3">Meet the Unit <Icon name="arrow" size={16} /></a>
      </div>
      <ul class="intel-list manifesto-list">
        <li><b class="text-ink">Observe first.</b> See it clearly before you say a word about it.</li>
        <li><b class="text-ink">Own the signal.</b> Build like the tower's already down — mirror everything.</li>
        <li><b class="text-ink">Forward, always.</b> The position is temporary; the direction isn't.</li>
        <li><b class="text-ink">Bring the others.</b> A unit, a tribe, a comment section that has your back.</li>
      </ul>
    </div>
  </section>

  <!-- ===== BROADCAST ===== -->
  <section class="section broadcast-section">
    <div class="container">
      <div class="sec-top">
        <SectionHead
          eyebrow="Broadcast" jp="放送" variant="red"
          title="Four channels. One signal."
          lead="Long-form radio, field documentary, recovered uploads, and after-dark livestreams. Wherever it lands, it's the same voice from the same edge."
        />
        <a href="/broadcast/" class="btn btn-ghost sec-top-cta">All Channels <Icon name="arrow" size={16} /></a>
      </div>
      <div class="grid grid-4 mt-6 shows-grid">
        {shows.map((s) => <ShowCard show={s} />)}
      </div>
    </div>
  </section>

  <!-- ===== LATEST TRANSMISSIONS ===== -->
  <section class="section transmissions scanlines">
    <div class="container">
      <SectionHead
        eyebrow="Latest Transmissions" jp="実況" variant="cyan"
        title="Fresh off the net"
      />
      <div class="ep-list mt-6">
        {latestEpisodes.map((e) => (
          <a href="/broadcast/" class="ep-row">
            <span class="ep-play"><Icon name="play" size={16} /></span>
            <span class="ep-num mono">{e.ep}</span>
            <span class="ep-main">
              <span class="ep-title">{e.title}</span>
              <span class="ep-desc">{e.desc}</span>
            </span>
            <span class="tag is-red ep-tag">{e.tag}</span>
            <span class="ep-dur mono">{e.duration}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== DISPATCHES ===== -->
  <section class="section">
    <div class="container">
      <div class="sec-top">
        <SectionHead
          eyebrow="Dispatches" jp="通信" variant="amber"
          title="From the grey zone"
          lead="Field notes and signal-war essays from forward of the line. Some recovered from channels that no longer exist."
        />
        <a href="/dispatches/" class="btn btn-ghost sec-top-cta">All Dispatches <Icon name="arrow" size={16} /></a>
      </div>
      <div class="dispatch-grid mt-6">
        <DispatchCard dispatch={featured} featured />
        <div class="dispatch-stack">
          {moreDispatches.map((d) => <DispatchCard dispatch={d} />)}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SUPPLY ===== -->
  <section class="section supply-section scanlines">
    <div class="container">
      <div class="sec-top">
        <SectionHead
          eyebrow="Supply" jp="補給" variant="red"
          title="Kit for the observant"
          lead="We make the stuff we'd actually wear. Drops are limited by design — when a colorway's gone, it's gone."
        />
        <a href="/supply/" class="btn btn-ghost sec-top-cta">Enter Supply <Icon name="arrow" size={16} /></a>
      </div>
      <div class="grid grid-3 mt-6">
        {supplyPreview.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>

<style>
  /* ===== HERO ===== */
  .hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(820px 420px at 12% -5%, rgba(255, 35, 64, 0.16), transparent 60%),
      radial-gradient(760px 500px at 105% 10%, rgba(34, 224, 255, 0.1), transparent 55%),
      var(--void);
  }
  .hero-scan-bloom {
    position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(900px 500px at 60% 120%, rgba(160, 107, 255, 0.14), transparent 60%);
  }
  .hero-grid {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .hero-title {
    font-size: var(--step-5);
    line-height: 0.92;
    letter-spacing: -0.02em;
    margin: 1.1rem 0 0;
    max-width: 15ch;
    text-transform: uppercase;
  }
  .hero-lead { margin-top: 1.4rem; max-width: 52ch; }
  .hero-cta { margin-top: 2rem; }
  .hero-channels {
    margin-top: 1.6rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .hero-channels a { color: var(--muted); }
  .hero-channels a:hover { color: var(--cyan); }
  .hero-channels .sep { color: var(--red); opacity: 0.6; }

  /* Console / radar */
  .console { display: grid; gap: 1rem; background: rgba(8, 10, 18, 0.7); }
  .console-head {
    display: flex; align-items: center; justify-content: space-between;
    font-size: 0.7rem; letter-spacing: 0.14em; text-transform: uppercase; color: var(--muted);
  }
  .console-head .status-dot { display: inline-block; margin-right: 0.4rem; vertical-align: middle; }
  .radar {
    position: relative;
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid rgba(34, 224, 255, 0.3);
    background: radial-gradient(circle at center, rgba(34, 224, 255, 0.08), transparent 70%), #04070c;
  }
  .radar-rings {
    position: absolute; inset: 0;
    background: repeating-radial-gradient(circle at center, transparent 0 15%, rgba(34, 224, 255, 0.13) 15%, transparent 15.4%);
  }
  .radar-cross::before, .radar-cross::after {
    content: ""; position: absolute; background: rgba(34, 224, 255, 0.18);
  }
  .radar-cross::before { inset: 50% 0 auto 0; height: 1px; }
  .radar-cross::after { inset: 0 50% 0 auto; width: 1px; }
  .radar-sweep {
    position: absolute; inset: 0; border-radius: 50%;
    background: conic-gradient(from 0deg, transparent 0 296deg, rgba(34, 224, 255, 0.25) 340deg, rgba(34, 224, 255, 0.6) 360deg);
    animation: sweep 3.6s linear infinite;
  }
  @keyframes sweep { to { transform: rotate(360deg); } }
  .blip {
    position: absolute;
    left: var(--x); top: var(--y);
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--red); box-shadow: 0 0 8px var(--red);
    animation: ping 3.6s ease-out infinite;
    animation-delay: var(--d);
  }
  @keyframes ping {
    0%, 60% { transform: scale(0.6); opacity: 0; }
    62% { transform: scale(1.3); opacity: 1; }
    100% { transform: scale(0.6); opacity: 0; }
  }
  .console-readout { display: grid; gap: 0.4rem; font-size: 0.72rem; letter-spacing: 0.06em; }
  .console-readout .row {
    display: flex; justify-content: space-between;
    padding-bottom: 0.35rem; border-bottom: 1px dashed var(--line);
    color: var(--muted); text-transform: uppercase;
  }
  .text-lime { color: var(--lime); }

  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .console { max-width: 420px; }
  }

  /* ===== Shared section bits ===== */
  .sec-top {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .sec-top .section-head { flex: 1; min-width: 280px; }
  .sec-top-cta { flex: none; }

  .stats-band { border-bottom: 1px solid var(--line); background: var(--void-2); }
  .stats-grid { text-align: left; }
  .stat { padding: 0.5rem 0; border-left: 2px solid var(--red); padding-left: 1rem; }
  .stat-label .jp { margin-left: 0.3rem; font-size: 0.7rem; }

  .manifesto {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }
  .manifesto-list { font-size: 1.02rem; gap: 1rem; }
  @media (max-width: 820px) { .manifesto { grid-template-columns: 1fr; } }

  .transmissions {
    background:
      radial-gradient(600px 300px at 100% 0%, rgba(34, 224, 255, 0.06), transparent 60%),
      var(--void-2);
    border-block: 1px solid var(--line);
  }
  .ep-list { display: grid; gap: 0.4rem; }
  .ep-row {
    display: grid;
    grid-template-columns: auto auto 1fr auto auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--line);
    color: var(--body);
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s var(--ease);
  }
  .ep-row:hover {
    border-color: rgba(34, 224, 255, 0.4);
    background: var(--surface-2);
    transform: translateX(4px);
  }
  .ep-play {
    display: grid; place-items: center;
    width: 2.2rem; height: 2.2rem; flex: none;
    color: var(--red);
    border: 1px solid rgba(255, 35, 64, 0.4);
    background: rgba(255, 35, 64, 0.08);
    border-radius: 50%;
  }
  .ep-row:hover .ep-play { color: #fff; background: var(--red); }
  .ep-num { color: var(--amber); font-size: 0.8rem; min-width: 3.2rem; }
  .ep-main { display: flex; flex-direction: column; gap: 0.15rem; min-width: 0; }
  .ep-title { font-family: var(--font-display); font-weight: 600; color: var(--ink); font-size: 1.02rem; }
  .ep-desc {
    color: var(--muted); font-size: 0.85rem;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .ep-dur { color: var(--dim); font-size: 0.8rem; }
  @media (max-width: 700px) {
    .ep-row { grid-template-columns: auto 1fr auto; }
    .ep-num, .ep-desc { display: none; }
  }

  .dispatch-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(1rem, 2.5vw, 1.5rem);
    align-items: start;
  }
  .dispatch-stack { display: grid; gap: clamp(1rem, 2.5vw, 1.5rem); }
  @media (max-width: 860px) { .dispatch-grid { grid-template-columns: 1fr; } }

  .supply-section {
    background:
      radial-gradient(600px 300px at 0% 100%, rgba(255, 35, 64, 0.06), transparent 60%),
      var(--void-2);
    border-block: 1px solid var(--line);
  }
</style>
