---
import Marquee from "./Marquee.astro";
import Breadcrumbs from "./Breadcrumbs.astro";
interface Props {
  eyebrow: string;
  jp?: string;
  title: string;
  lead?: string;
  variant?: "amber" | "red" | "cyan";
  crumbs?: { name: string; url: string }[];
}
const { eyebrow, jp, title, lead, variant = "red", crumbs } = Astro.props;
---

<section class="page-hero scanlines">
  <div class="grid-floor"></div>
  <div class="container page-hero-inner">
    {crumbs && <Breadcrumbs crumbs={crumbs} />}
    <span class:list={["eyebrow", { "is-red": variant === "red", "is-cyan": variant === "cyan" }]}>
      {eyebrow}{jp && <span class="jp hero-jp">{jp}</span>}
    </span>
    <h1 class="h1 display glitch" data-text={title}>{title}</h1>
    {lead && <p class="lead mt-2">{lead}</p>}
  </div>
  <Marquee />
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
    background:
      radial-gradient(700px 340px at 20% 0%, rgba(255, 35, 64, 0.12), transparent 60%),
      var(--void);
  }
  .page-hero-inner {
    padding-block: clamp(2.4rem, 7vw, 4.5rem) clamp(2rem, 5vw, 3rem);
    position: relative;
    z-index: 3;
  }
  .page-hero h1 { margin-top: 0.9rem; max-width: 22ch; }
  .page-hero .lead { max-width: 58ch; }
  .hero-jp { margin-left: 0.6rem; opacity: 0.85; letter-spacing: 0.1em; }
</style>
