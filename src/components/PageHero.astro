---
import Breadcrumbs from "./Breadcrumbs.astro";
import Icon from "./Icon.astro";
import { site } from "../data/site";
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  crumbs?: { name: string; url: string }[];
  showCta?: boolean;
}
const { eyebrow, title, text, crumbs, showCta = true } = Astro.props;
---

<section class="page-hero section-dark">
  <div class="container">
    {crumbs && <Breadcrumbs crumbs={crumbs} />}
    <div class="page-hero-inner">
      {eyebrow && <span class="eyebrow is-light">{eyebrow}</span>}
      <h1 class="h1">{title}</h1>
      {text && <p class="lead">{text}</p>}
      {showCta && (
        <div class="btn-group mt-3">
          <a href="/contact/" class="btn btn-accent">Get a Free Quote</a>
          <a href={site.phone.href} class="btn btn-outline-light">
            <Icon name="phone" size={18} /> {site.phone.display}
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero { padding-block: clamp(1.6rem, 4vw, 2.2rem) clamp(2.8rem, 6vw, 4.5rem); }
  .page-hero-inner { max-width: 60ch; margin-top: 1.4rem; }
  .page-hero .h1 { margin-bottom: 0.9rem; }
</style>
