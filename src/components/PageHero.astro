---
import Breadcrumbs from "./Breadcrumbs.astro";
import Icon from "./Icon.astro";
import { site } from "../data/site";
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  crumbs?: { name: string; url: string }[];
  showCta?: boolean;
  image?: string;
  imageAlt?: string;
}
const {
  eyebrow,
  title,
  text,
  crumbs,
  showCta = true,
  image,
  imageAlt = "",
} = Astro.props;
---

<section class:list={["page-hero section-dark", { "has-media": image }]}>
  {image && (
    <div class="page-hero-media" aria-hidden={imageAlt ? undefined : "true"}>
      <img src={image} alt={imageAlt} width="1800" height="1100" fetchpriority="high" decoding="async" />
      <div class="page-hero-scrim"></div>
    </div>
  )}
  <div class="container">
    {crumbs && <Breadcrumbs crumbs={crumbs} />}
    <div class="page-hero-inner">
      {eyebrow && <span class="eyebrow is-light">{eyebrow}</span>}
      <h1 class="h1">{title}</h1>
      {text && <p class="lead">{text}</p>}
      {showCta && (
        <div class="btn-group mt-3">
          <a href="/contact/" class="btn btn-accent">Get a Free Quote</a>
          <a href={site.phone.href} class="btn btn-outline-light">
            <Icon name="phone" size={18} /> {site.phone.display}
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(1.6rem, 4vw, 2.2rem) clamp(2.8rem, 6vw, 4.5rem);
  }
  .page-hero.has-media { padding-block: clamp(2rem, 5vw, 3rem) clamp(3.2rem, 7vw, 5rem); }
  .page-hero-media { position: absolute; inset: 0; z-index: 0; }
  .page-hero-media img { width: 100%; height: 100%; object-fit: cover; object-position: 50% 45%; }
  .page-hero-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(94deg,
        rgba(10, 31, 61, 0.95) 0%,
        rgba(10, 31, 61, 0.86) 42%,
        rgba(10, 31, 61, 0.6) 74%,
        rgba(10, 31, 61, 0.4) 100%);
  }
  .page-hero .container { position: relative; z-index: 1; }
  .page-hero-inner { max-width: 62ch; margin-top: 1.4rem; }
  .page-hero .h1 { margin-bottom: 0.9rem; }
</style>
