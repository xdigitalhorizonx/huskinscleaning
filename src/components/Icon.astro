const d = paths[name] ?? paths["sparkle"];
const dim = typeof size === "number" ? `${size}` : size;
const hasLabel = Boolean(rest["aria-label"]);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={hasLabel ? "img" : "presentation"}
  aria-hidden={hasLabel ? undefined : "true"}
  {...rest}
  set:html={d}
/>
