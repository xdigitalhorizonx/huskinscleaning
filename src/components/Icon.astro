  "arrow-up-right": '<path d="M7 17 17 7M8 7h9v9"/>',
  shield:
    '<path d="M12 3 5 6v5c0 4.5 3 7.9 7 10 4-2.1 7-5.5 7-10V6z"/><path d="m9 12 2 2 4-4"/>',
  leaf: '<path d="M4 20c0-8 6-14 16-14 0 10-6 16-14 16"/><path d="M6 18C10 12 14 10 18 9"/>',
  calendar:
    '<rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 9h18M8 3v4M16 3v4"/>',
