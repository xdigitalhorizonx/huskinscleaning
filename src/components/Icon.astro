---
/**
 * Inline SVG icon set (stroke style, 24×24 viewBox).
 * Hand-authored so there is zero icon-font dependency and every icon
 * inherits `currentColor`. Add new glyphs to the `paths` map below.
 */
interface Props {
  name: string;
  size?: number | string;
  class?: string;
  "aria-label"?: string;
}

const { name, size = 24, class: className = "", ...rest } = Astro.props;

const paths: Record<string, string> = {
  // navigation / ui
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  "arrow-up-right": '<path d="M7 17 17 7M8 7h9v9"/>',
  "chevron-down": '<path d="m6 9 6 6 6-6"/>',
  "chevron-right": '<path d="m9 6 6 6-6 6"/>',
  external: '<path d="M14 4h6v6M20 4l-9 9"/><path d="M18 14v5a1 1 0 0 1-1 1H5a1 1 0 0 1-1-1V7a1 1 0 0 1 1-1h5"/>',
  menu: '<path d="M3 6h18M3 12h18M3 18h18"/>',
  close: '<path d="M6 6l12 12M18 6 6 18"/>',
  plus: '<path d="M12 5v14M5 12h14"/>',
  check: '<path d="M20 6 9 17l-5-5"/>',

  // FOG thematic
  crosshair: '<circle cx="12" cy="12" r="8"/><path d="M12 2v4M12 18v4M2 12h4M18 12h4"/><circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/>',
  target: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="0.6" fill="currentColor" stroke="none"/>',
  eye: '<path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z"/><circle cx="12" cy="12" r="3"/>',
  radio: '<circle cx="12" cy="12" r="2"/><path d="M7.8 7.8a6 6 0 0 0 0 8.4M16.2 7.8a6 6 0 0 1 0 8.4"/><path d="M5 5a10 10 0 0 0 0 14M19 5a10 10 0 0 1 0 14"/>',
  satellite: '<path d="M4 12 2 14l4 4 2-2M12 4l2-2 4 4-2 2"/><path d="M6 10 10 6l8 8-4 4z"/><path d="M15 9a3 3 0 0 1 3 3"/>',
  signal: '<path d="M4 20V10M9 20V6M14 20v-9M19 20V3"/>',
  broadcast: '<circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 0 1 0 8.49M7.76 16.24a6 6 0 0 1 0-8.49M19.07 4.93a10 10 0 0 1 0 14.14M4.93 19.07a10 10 0 0 1 0-14.14"/>',
  headphones: '<path d="M4 14v-2a8 8 0 0 1 16 0v2"/><rect x="2.5" y="13" width="4.5" height="7" rx="1.5"/><rect x="17" y="13" width="4.5" height="7" rx="1.5"/>',
  play: '<path d="M7 4.5 20 12 7 19.5z"/>',
  film: '<rect x="3" y="4" width="18" height="16" rx="1.5"/><path d="M7 4v16M17 4v16M3 9h4M17 9h4M3 15h4M17 15h4"/>',
  terminal: '<rect x="3" y="4" width="18" height="16" rx="1.5"/><path d="m7 9 3 3-3 3M13 15h4"/>',
  rss: '<path d="M5 19a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" fill="currentColor" stroke="none"/><path d="M4 4a16 16 0 0 1 16 16M4 10a10 10 0 0 1 10 10"/>',
  bag: '<path d="M5 8h14l-1 12H6z"/><path d="M9 8V6a3 3 0 0 1 6 0v2"/>',
  shirt: '<path d="M8 3 4 6l2 3 2-1.2V21h8V7.8L18 9l2-3-4-3-2 2a2.4 2.4 0 0 1-4 0z"/>',
  map: '<path d="m9 4-6 2v14l6-2 6 2 6-2V4l-6 2-6-2z"/><path d="M9 4v14M15 6v14"/>',
  globe: '<circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3.5 3 14.5 0 18M12 3c-3 3.5-3 14.5 0 18"/>',
  send: '<path d="M22 2 11 13M22 2l-7 20-4-9-9-4z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="1.5"/><path d="m3 7 9 6 9-6"/>',
  alert: '<path d="M12 3 2 20h20z"/><path d="M12 9v5M12 17.5v.5" stroke-width="2.4"/>',
  clock: '<circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/>',
  calendar: '<rect x="3" y="5" width="18" height="16" rx="1.5"/><path d="M3 9h18M8 3v4M16 3v4"/>',
  shield: '<path d="M12 3 5 6v5c0 4.5 3 7.9 7 10 4-2.1 7-5.5 7-10V6z"/><path d="m9 12 2 2 4-4"/>',
  users: '<circle cx="9" cy="8" r="3.2"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 6.2a3.2 3.2 0 0 1 0 6.1M17.5 20a5.5 5.5 0 0 0-3.2-5"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5z"/>',
  pin: '<path d="M12 21s-7-6-7-11a7 7 0 0 1 14 0c0 5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/>',
  quote: '<path d="M7 7c-2.5 1-4 3.2-4 6v4h6v-6H5c0-1.6.8-2.9 2-3.6zM19 7c-2.5 1-4 3.2-4 6v4h6v-6h-4c0-1.6.8-2.9 2-3.6z"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6z"/>',

  // social (filled brand marks where cleaner)
  instagram: '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.2" fill="currentColor" stroke="none"/>',
  youtube: '<rect x="2.5" y="6" width="19" height="12" rx="3.5"/><path d="M10 9.2 15 12l-5 2.8z" fill="currentColor" stroke="none"/>',
  spotify: '<circle cx="12" cy="12" r="9"/><path d="M7.5 10c3-.8 6.5-.5 9 1M8 13c2.5-.6 5-.4 7 .8M8.6 15.6c2-.4 3.8-.2 5.4.6"/>',
  x: '<path d="M4 4l16 16M20 4 4 20" />',
  tiktok: '<path d="M14 4v9.5a3.5 3.5 0 1 1-3-3.46"/><path d="M14 4a5 5 0 0 0 5 5"/>',
};

const d = paths[name] ?? paths["crosshair"];
const dim = typeof size === "number" ? `${size}` : size;
const hasLabel = Boolean(rest["aria-label"]);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={dim}
  height={dim}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  role={hasLabel ? "img" : "presentation"}
  aria-hidden={hasLabel ? undefined : "true"}
  {...rest}
  set:html={d}
/>
