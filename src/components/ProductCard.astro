---
import Icon from "./Icon.astro";
import type { Product } from "../data/site";
interface Props { product: Product; }
const { product: p } = Astro.props;

const statusClass: Record<Product["status"], string> = {
  "IN STOCK": "is-lime",
  "LOW STOCK": "is-amber",
  "SOLD OUT": "is-red",
  "DROP": "is-cyan",
};
const soldOut = p.status === "SOLD OUT";
---

<article class:list={["product-card panel panel-hover", { "is-out": soldOut }]}>
  <div class="pc-visual scanlines" aria-hidden="true">
    <span class="pc-glyph jp">{p.jp}</span>
    <span class="pc-reticle"></span>
    <span class:list={["tag pc-status", statusClass[p.status]]}>
      {!soldOut && <span class="status-dot"></span>}{p.status}
    </span>
  </div>
  <div class="pc-body">
    <h3 class="h3 pc-name">{p.name}</h3>
    <p class="pc-type mono">{p.type}</p>
    <p class="pc-colorway mono"><span class="dim">COLORWAY //</span> {p.colorway}</p>
    <div class="pc-foot">
      <span class="pc-price">{p.price}</span>
      <button class="btn btn-ghost pc-btn" disabled={soldOut}>
        <Icon name="bag" size={15} /> {soldOut ? "Sold Out" : "Add to Kit"}
      </button>
    </div>
  </div>
</article>

<style>
  .product-card { padding: 0; display: flex; flex-direction: column; overflow: hidden; }
  .product-card::before, .product-card::after { border-color: var(--line-strong); z-index: 4; }

  .pc-visual {
    position: relative;
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    overflow: hidden;
    background:
      radial-gradient(120% 120% at 50% 30%, rgba(255, 35, 64, 0.12), transparent 60%),
      repeating-linear-gradient(90deg, rgba(148,163,184,0.05) 0 1px, transparent 1px 30px),
      repeating-linear-gradient(0deg, rgba(148,163,184,0.05) 0 1px, transparent 1px 30px),
      var(--void-2);
    border-bottom: 1px solid var(--line);
  }
  .pc-glyph {
    font-size: clamp(3.5rem, 12vw, 5.5rem);
    color: rgba(238, 241, 248, 0.9);
    text-shadow: 0 0 24px rgba(255, 35, 64, 0.45);
    line-height: 1;
  }
  .pc-reticle {
    position: absolute;
    width: 62%; aspect-ratio: 1;
    border: 1px solid rgba(34, 224, 255, 0.28);
    border-radius: 50%;
  }
  .pc-reticle::before, .pc-reticle::after {
    content: ""; position: absolute; background: rgba(34, 224, 255, 0.28);
  }
  .pc-reticle::before { inset: 50% -8% auto -8%; height: 1px; }
  .pc-reticle::after { inset: -8% 50% -8% auto; width: 1px; }
  .pc-status { position: absolute; top: 0.7rem; left: 0.7rem; z-index: 3; }
  .is-out .pc-glyph { color: var(--dim); text-shadow: none; opacity: 0.6; }

  .pc-body { padding: 1.1rem 1.2rem 1.2rem; display: flex; flex-direction: column; gap: 0.35rem; flex: 1; }
  .pc-name { font-size: 1.15rem; }
  .pc-type { font-size: 0.72rem; letter-spacing: 0.06em; color: var(--muted); text-transform: uppercase; }
  .pc-colorway { font-size: 0.72rem; letter-spacing: 0.04em; color: var(--body); }
  .pc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: auto;
    padding-top: 0.9rem;
  }
  .pc-price {
    font-family: var(--font-num);
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--ink);
  }
  .pc-btn { padding: 0.6rem 1rem; font-size: 0.8rem; }
  .pc-btn:disabled { opacity: 0.4; cursor: not-allowed; }
</style>
