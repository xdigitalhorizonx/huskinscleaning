---
import Icon from "./Icon.astro";
interface Props { count?: number; label?: string; }
const { count = 5, label } = Astro.props;
---
<span class="stars" role="img" aria-label={label ?? `${count} out of 5 stars`}>
  {Array.from({ length: count }).map(() => <Icon name="star" />)}
</span>
<style>
  .stars :global(svg) { fill: var(--star); stroke: var(--star); }
</style>
