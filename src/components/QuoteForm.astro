---
import Icon from "./Icon.astro";
import { site, services } from "../data/site";
---

<form class="quote-form card" id="quote-form" novalidate>
  <div class="qf-head">
    <h3 class="h3">Request your free quote</h3>
    <p class="muted">Tell us a little about your space and we'll get back to you fast — usually the same day.</p>
  </div>

  <div class="qf-grid">
    <label class="qf-field">
      <span>Full name <b>*</b></span>
      <input type="text" name="name" autocomplete="name" required placeholder="Jane Smith" />
    </label>
    <label class="qf-field">
      <span>Phone <b>*</b></span>
      <input type="tel" name="phone" autocomplete="tel" required placeholder="(402) 555-0123" />
    </label>
    <label class="qf-field">
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" placeholder="you@email.com" />
    </label>
    <label class="qf-field">
      <span>Service needed</span>
      <select name="service">
        <option value="">Choose a service…</option>
        {services.map((s) => <option value={s.title}>{s.title}</option>)}
        <option value="Not sure yet">Not sure yet</option>
      </select>
    </label>
    <label class="qf-field">
      <span>ZIP / neighborhood</span>
      <input type="text" name="location" placeholder="68112 — North Omaha" />
    </label>
    <label class="qf-field">
      <span>Preferred date</span>
      <input type="date" name="date" />
    </label>
    <label class="qf-field qf-full">
      <span>Anything else?</span>
      <textarea name="message" rows="3" placeholder="Square footage, bedrooms/baths, one-time vs. recurring, pets, etc."></textarea>
    </label>
  </div>

  <!-- Honeypot for spam bots -->
  <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="qf-honeypot" aria-hidden="true" />

  <button type="submit" class="btn btn-accent btn-lg btn-block">
    <Icon name="sparkles" size={20} /> Send My Free Quote Request
  </button>
  <p class="qf-alt">
    Prefer to talk? Call <a href={site.phone.href}>{site.phone.display}</a> — {site.hours.label}
  </p>

  <div class="qf-success" id="qf-success" hidden>
    <span class="qf-success-icon"><Icon name="check-circle" size={30} /></span>
    <h3 class="h3">Thanks — your request is in!</h3>
    <p>We've received your details and a member of the Huskins team will reach out shortly. Need us sooner? Call <a href={site.phone.href}>{site.phone.display}</a>.</p>
  </div>
</form>

<style>
  .quote-form { padding: clamp(1.4rem, 3vw, 2.2rem); }
  .qf-head { margin-bottom: 1.4rem; }
  .qf-head p { margin-top: 0.4rem; }
  .qf-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .qf-field { display: flex; flex-direction: column; gap: 0.35rem; }
  .qf-full { grid-column: 1 / -1; }
  .qf-field span { font-size: 0.85rem; font-weight: 600; color: var(--ink); font-family: var(--font-display); }
  .qf-field b { color: var(--accent-700); }
  .qf-field input,
  .qf-field select,
  .qf-field textarea {
    font: inherit;
    font-size: 0.95rem;
    padding: 0.7rem 0.85rem;
    border: 1.5px solid var(--line-strong);
    border-radius: 10px;
    background: var(--canvas);
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
    width: 100%;
  }
  .qf-field input:focus,
  .qf-field select:focus,
  .qf-field textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px var(--brand-100);
  }
  .qf-field [aria-invalid="true"] { border-color: #dc4444; box-shadow: 0 0 0 3px #fbe0e0; }
  .qf-honeypot { position: absolute; left: -9999px; width: 1px; height: 1px; opacity: 0; }
  #quote-form button[type="submit"] { margin-top: 1.4rem; }
  .qf-alt { text-align: center; margin-top: 0.9rem; font-size: 0.9rem; color: var(--muted); }
  .qf-alt a { font-weight: 700; }

  .qf-success { text-align: center; padding: 1rem 0; }
  .qf-success-icon {
    display: inline-grid;
    place-items: center;
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--brand-100);
    color: var(--brand-700);
    margin-bottom: 1rem;
  }
  .qf-success h3 { margin-bottom: 0.5rem; }

  @media (max-width: 560px) {
    .qf-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.getElementById("quote-form") as HTMLFormElement | null;
  const success = document.getElementById("qf-success");

  // Configure a form endpoint (Formspree, Web3Forms, etc.) to receive
  // submissions by email. Until then, the form validates and confirms locally
  // and the phone number remains the primary, always-working contact path.
  const ENDPOINT = ""; // e.g. "https://formspree.io/f/xxxxxxx"

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form) return;

    // Honeypot: silently succeed for bots.
    if ((form.elements.namedItem("_gotcha") as HTMLInputElement)?.value) {
      revealSuccess();
      return;
    }

    let valid = true;
    for (const name of ["name", "phone"]) {
      const field = form.elements.namedItem(name) as HTMLInputElement;
      const ok = field.value.trim().length > 1;
      field.setAttribute("aria-invalid", ok ? "false" : "true");
      if (!ok) valid = false;
    }
    if (!valid) {
      (form.querySelector('[aria-invalid="true"]') as HTMLElement)?.focus();
      return;
    }

    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = "Sending…";

    try {
      if (ENDPOINT) {
        const res = await fetch(ENDPOINT, {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        if (!res.ok) throw new Error("Bad response");
      }
      revealSuccess();
    } catch {
      btn.disabled = false;
      btn.textContent = "Try again";
      alert("Sorry — something went wrong sending your request. Please call us at (402) 249-0449 and we'll get you taken care of right away.");
    }
  });

  function revealSuccess() {
    if (!form || !success) return;
    Array.from(form.children).forEach((c) => {
      if (c !== success) (c as HTMLElement).style.display = "none";
    });
    success.hidden = false;
    success.scrollIntoView({ behavior: "smooth", block: "center" });
  }
</script>
