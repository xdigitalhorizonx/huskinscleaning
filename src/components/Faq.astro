---
import Icon from "./Icon.astro";
import { faqs as allFaqs } from "../data/site";
import type { Faq } from "../data/site";
interface Props {
  items?: Faq[];
  heading?: string;
  intro?: string;
}
const {
  items = allFaqs,
  heading = "Questions we get a lot",
  intro = "Straight answers on pricing, timelines, and how we work — no jargon. Still curious? Start a conversation.",
} = Astro.props;
---

<section class="section" id="faq">
  <div class="container faq-wrap">
    <div class="section-head">
      <span class="eyebrow is-cyan">FAQ</span>
      <h2 class="h2 display mt-1">{heading}</h2>
      <p class="lead mt-2">{intro}</p>
      <div class="rule-label mt-4">NO JARGON · STRAIGHT ANSWERS</div>
    </div>
    <div class="faq-list">
      {items.map((f, i) => (
        <details class="faq-item" open={i === 0}>
          <summary>
            <span class="faq-q"><span class="faq-idx mono">{String(i + 1).padStart(2, "0")}</span>{f.question}</span>
            <Icon name="plus" class="faq-chevron" size={18} />
          </summary>
          <div class="faq-answer"><p>{f.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-wrap {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: start;
  }
  .faq-list { display: grid; gap: 0.7rem; }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 0 1.3rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .faq-item[open] {
    border-color: rgba(34, 224, 255, 0.4);
    background: linear-gradient(180deg, rgba(34, 224, 255, 0.04), transparent);
  }
  .faq-item summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.15rem 0;
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-q {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.02rem;
    color: var(--ink);
  }
  .faq-idx { color: var(--red); font-size: 0.8rem; }
  .faq-item :global(.faq-chevron) {
    color: var(--cyan);
    flex: none;
    transition: transform 0.25s var(--ease);
  }
  .faq-item[open] :global(.faq-chevron) { transform: rotate(135deg); }
  .faq-answer { padding: 0 0 1.2rem 1.9rem; color: var(--body); }
  .faq-answer p { max-width: 62ch; }

  @media (max-width: 820px) {
    .faq-wrap { grid-template-columns: 1fr; }
    .faq-answer { padding-left: 0; }
  }
</style>
