---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { site, nav } from "../data/site";

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || path.startsWith(href) && href !== "/";
---

<header class="site-header" id="site-header">
  <!-- HUD system bar -->
  <div class="sys-bar">
    <div class="container sys-inner mono">
      <span class="sys-item">
        <span class="status-dot"></span>
        SYS: ONLINE <span class="sys-jp">実況</span>
      </span>
      <span class="sys-item sys-mid">SIGNAL <span class="sys-green">● GREEN</span></span>
      <span class="sys-spacer"></span>
      <span class="sys-item sys-loc">LAT 50.4°N // LON 30.5°E</span>
      <span class="sys-item"><span class="rec">● REC</span> <time id="sys-clock" datetime="">--:--:-- UTC</time></span>
    </div>
  </div>

  <!-- Main nav -->
  <div class="nav-bar">
    <div class="container nav-inner">
      <Logo />

      <nav class="nav-desktop" aria-label="Primary">
        <ul class="nav-list">
          {nav.map((item, i) => (
            <li>
              <a href={item.href} class:list={["nav-link", { active: isActive(item.href) }]}>
                <span class="nav-idx">{String(i + 1).padStart(2, "0")}</span>
                <span class="nav-labels">
                  <span class="nav-jp">{item.jp}</span>
                  <span class="nav-en">{item.label}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="nav-cta">
        <div class="nav-social" aria-label="Channels">
          <a href={site.social.youtube} aria-label="YouTube" target="_blank" rel="noopener"><Icon name="youtube" size={18} /></a>
          <a href={site.social.spotify} aria-label="Spotify" target="_blank" rel="noopener"><Icon name="spotify" size={18} /></a>
          <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener"><Icon name="instagram" size={18} /></a>
        </div>
        <a href="/broadcast/" class="btn btn-primary btn-watch">
          <Icon name="play" size={15} /> Watch Live
        </a>
      </div>

      <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="m-link">
          <span>{item.label}</span>
          <span class="jp m-jp">{item.jp}</span>
        </a>
      ))}
      <div class="m-actions">
        <a href="/broadcast/" class="btn btn-primary btn-block"><Icon name="play" size={15} /> Watch Live</a>
        <div class="m-social">
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube"><Icon name="youtube" size={22} /></a>
          <a href={site.social.spotify} target="_blank" rel="noopener" aria-label="Spotify"><Icon name="spotify" size={22} /></a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" size={22} /></a>
          <a href={site.social.x} target="_blank" rel="noopener" aria-label="X"><Icon name="x" size={22} /></a>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; }

  /* System bar */
  .sys-bar {
    background: #000;
    border-bottom: 1px solid var(--line);
    font-size: 0.68rem;
    color: var(--muted);
  }
  .sys-inner {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    height: 30px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .sys-item { display: inline-flex; align-items: center; gap: 0.5rem; }
  .sys-jp { color: var(--amber); }
  .sys-green { color: var(--lime); }
  .sys-spacer { flex: 1; }
  .rec { color: var(--red); animation: blink 1.2s steps(1) infinite; }
  #sys-clock { color: var(--cyan); }
  @media (max-width: 860px) { .sys-mid, .sys-loc { display: none; } }
  @media (max-width: 520px) { .sys-bar { display: none; } }

  /* Nav bar */
  .nav-bar {
    background: rgba(6, 8, 14, 0.82);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--line);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  :global(.header-scrolled) .nav-bar {
    border-bottom-color: rgba(255, 35, 64, 0.4);
    box-shadow: 0 12px 40px -20px rgba(255, 35, 64, 0.5);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 68px;
  }

  .nav-list {
    display: flex;
    align-items: stretch;
    gap: 0.1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.85rem;
    height: 68px;
    color: var(--body);
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .nav-idx {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--dim);
  }
  .nav-labels { display: flex; flex-direction: column; line-height: 1.1; }
  .nav-jp {
    font-family: var(--font-jp);
    font-size: 0.6rem;
    color: var(--amber);
    letter-spacing: 0.1em;
    opacity: 0.75;
  }
  .nav-en {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .nav-link:hover, .nav-link.active {
    color: #fff;
    border-bottom-color: var(--red);
    background: linear-gradient(180deg, transparent, rgba(255, 35, 64, 0.08));
  }
  .nav-link:hover .nav-jp, .nav-link.active .nav-jp { opacity: 1; color: var(--red-bright); }

  .nav-cta { display: flex; align-items: center; gap: 1rem; }
  .nav-social { display: flex; gap: 0.7rem; }
  .nav-social a { color: var(--muted); }
  .nav-social a:hover { color: var(--cyan); }
  .btn-watch { padding: 0.7rem 1.1rem; font-size: 0.85rem; }

  .nav-burger {
    display: none;
    background: none; border: none; color: var(--ink);
    cursor: pointer; padding: 0.3rem;
  }

  /* Mobile menu */
  .mobile-menu {
    background: var(--void-2);
    border-bottom: 1px solid var(--line);
    padding: 0.4rem clamp(1.1rem, 4vw, 2rem) 1.4rem;
  }
  .m-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.95rem 0.3rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  .m-jp { color: var(--amber); font-size: 0.9rem; }
  .m-actions { display: grid; gap: 1rem; margin-top: 1.2rem; }
  .m-social { display: flex; justify-content: center; gap: 1.6rem; color: var(--muted); }
  .m-social a { color: var(--muted); }
  .m-social a:hover { color: var(--cyan); }

  @media (max-width: 940px) {
    .nav-desktop, .nav-cta { display: none; }
    .nav-burger { display: block; }
  }
  @media (min-width: 941px) {
    .mobile-menu { display: none !important; }
  }
</style>

<script>
  const header = document.getElementById("site-header");
  const burger = header?.querySelector(".nav-burger") as HTMLButtonElement | null;
  const menu = document.getElementById("mobile-menu");

  burger?.addEventListener("click", () => {
    const closed = menu?.hasAttribute("hidden");
    if (closed) {
      menu?.removeAttribute("hidden");
      burger.setAttribute("aria-expanded", "true");
      burger.setAttribute("aria-label", "Close menu");
    } else {
      menu?.setAttribute("hidden", "");
      burger.setAttribute("aria-expanded", "false");
      burger.setAttribute("aria-label", "Open menu");
    }
  });

  // Elevate header on scroll
  const onScroll = () =>
    document.documentElement.classList.toggle("header-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  // Live HUD clock (UTC)
  const clock = document.getElementById("sys-clock") as HTMLTimeElement | null;
  if (clock) {
    const tick = () => {
      const d = new Date();
      const t = d.toISOString().slice(11, 19);
      clock.textContent = `${t} UTC`;
      clock.dateTime = d.toISOString();
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
