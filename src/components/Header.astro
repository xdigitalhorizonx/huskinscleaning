---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { site, nav } from "../data/site";

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (path.startsWith(href) && href !== "/");
---

<header class="site-header" id="site-header">
  <!-- HUD status bar -->
  <div class="sys-bar">
    <div class="container sys-inner mono">
      <span class="sys-item">
        <span class="status-dot"></span> NOW BOOKING — NORTHERN NEVADA
      </span>
      <span class="sys-item sys-mid">WEB · SEO · DIGITAL MARKETING</span>
      <span class="sys-spacer"></span>
      <a class="sys-item sys-phone" href={site.phone.href}><Icon name="phone" size={13} /> {site.phone.display}</a>
      <span class="sys-item sys-loc">FREE 30-MIN DISCOVERY CALL</span>
    </div>
  </div>

  <!-- Main nav -->
  <div class="nav-bar">
    <div class="container nav-inner">
      <Logo />

      <nav class="nav-desktop" aria-label="Primary">
        <ul class="nav-list">
          {nav.map((item, i) => (
            <li>
              <a href={item.href} class:list={["nav-link", { active: isActive(item.href) }]}>
                <span class="nav-idx">{String(i + 1).padStart(2, "0")}</span>
                <span class="nav-en">{item.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="nav-cta">
        <div class="nav-social" aria-label="Social">
          <a href={site.social.facebook} aria-label="Facebook" target="_blank" rel="noopener"><Icon name="facebook" size={18} /></a>
          <a href={site.social.instagram} aria-label="Instagram" target="_blank" rel="noopener"><Icon name="instagram" size={18} /></a>
          <a href={site.social.x} aria-label="X" target="_blank" rel="noopener"><Icon name="x" size={16} /></a>
        </div>
        <a href="/contact/" class="btn btn-primary btn-start">
          <Icon name="rocket" size={15} /> Start a Project
        </a>
      </div>

      <button class="nav-burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <Icon name="menu" size={26} />
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu" hidden>
    <nav aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="m-link">{item.label}</a>
      ))}
      <div class="m-actions">
        <a href="/contact/" class="btn btn-primary btn-block"><Icon name="rocket" size={15} /> Start a Project</a>
        <a href={site.phone.href} class="btn btn-ghost btn-block"><Icon name="phone" size={15} /> {site.phone.display}</a>
        <div class="m-social">
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook"><Icon name="facebook" size={22} /></a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" size={22} /></a>
          <a href={site.social.x} target="_blank" rel="noopener" aria-label="X"><Icon name="x" size={20} /></a>
          <a href={site.social.nextdoor} target="_blank" rel="noopener" aria-label="Nextdoor"><Icon name="nextdoor" size={22} /></a>
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header { position: sticky; top: 0; z-index: 100; }

  /* Status bar */
  .sys-bar {
    background: #000;
    border-bottom: 1px solid var(--line);
    font-size: 0.68rem;
    color: var(--muted);
  }
  .sys-inner {
    display: flex;
    align-items: center;
    gap: 1.4rem;
    height: 30px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .sys-item { display: inline-flex; align-items: center; gap: 0.5rem; }
  .sys-spacer { flex: 1; }
  .sys-phone { color: var(--cyan); }
  .sys-phone:hover { color: var(--cyan-bright); }
  .sys-loc { color: var(--amber); }
  @media (max-width: 900px) { .sys-mid, .sys-loc { display: none; } }
  @media (max-width: 520px) { .sys-bar { display: none; } }

  /* Nav bar */
  .nav-bar {
    background: rgba(6, 8, 14, 0.82);
    backdrop-filter: saturate(140%) blur(14px);
    border-bottom: 1px solid var(--line);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  :global(.header-scrolled) .nav-bar {
    border-bottom-color: rgba(255, 90, 60, 0.4);
    box-shadow: 0 12px 40px -20px rgba(255, 90, 60, 0.5);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 68px;
  }

  .nav-list { display: flex; align-items: stretch; gap: 0.1rem; list-style: none; margin: 0; padding: 0; }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.9rem;
    height: 68px;
    color: var(--body);
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }
  .nav-idx { font-family: var(--font-mono); font-size: 0.6rem; color: var(--dim); }
  .nav-en {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .nav-link:hover, .nav-link.active {
    color: #fff;
    border-bottom-color: var(--red);
    background: linear-gradient(180deg, transparent, rgba(255, 90, 60, 0.08));
  }
  .nav-link:hover .nav-idx, .nav-link.active .nav-idx { color: var(--red-bright); }

  .nav-cta { display: flex; align-items: center; gap: 1rem; }
  .nav-social { display: flex; gap: 0.7rem; }
  .nav-social a { color: var(--muted); }
  .nav-social a:hover { color: var(--cyan); }
  .btn-start { padding: 0.7rem 1.1rem; font-size: 0.85rem; }

  .nav-burger { display: none; background: none; border: none; color: var(--ink); cursor: pointer; padding: 0.3rem; }

  /* Mobile menu */
  .mobile-menu {
    background: var(--void-2);
    border-bottom: 1px solid var(--line);
    padding: 0.4rem clamp(1.1rem, 4vw, 2rem) 1.4rem;
  }
  .m-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.95rem 0.3rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
  }
  .m-actions { display: grid; gap: 0.8rem; margin-top: 1.2rem; }
  .m-social { display: flex; justify-content: center; gap: 1.6rem; color: var(--muted); margin-top: 0.4rem; }
  .m-social a { color: var(--muted); }
  .m-social a:hover { color: var(--cyan); }

  @media (max-width: 940px) {
    .nav-desktop, .nav-cta { display: none; }
    .nav-burger { display: block; }
  }
  @media (min-width: 941px) { .mobile-menu { display: none !important; } }
</style>

<script>
  const header = document.getElementById("site-header");
  const burger = header?.querySelector(".nav-burger") as HTMLButtonElement | null;
  const menu = document.getElementById("mobile-menu");

  burger?.addEventListener("click", () => {
    const closed = menu?.hasAttribute("hidden");
    if (closed) {
      menu?.removeAttribute("hidden");
      burger.setAttribute("aria-expanded", "true");
      burger.setAttribute("aria-label", "Close menu");
    } else {
      menu?.setAttribute("hidden", "");
      burger.setAttribute("aria-expanded", "false");
      burger.setAttribute("aria-label", "Open menu");
    }
  });

  const onScroll = () =>
    document.documentElement.classList.toggle("header-scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
