---
import Icon from "./Icon.astro";
import type { Dispatch } from "../data/site";
interface Props { dispatch: Dispatch; featured?: boolean; }
const { dispatch: d, featured = false } = Astro.props;
const date = new Date(d.date + "T00:00:00Z").toLocaleDateString("en-US", {
  year: "numeric", month: "short", day: "2-digit", timeZone: "UTC",
});
---

<article class:list={["dispatch-card plate", { "is-featured": featured }]}>
  <div class="dc-head mono">
    <span class="tag is-red">{d.tag}</span>
    <span class="dc-class">{d.classification}</span>
  </div>
  <a href={`/dispatches/${d.slug}/`} class="dc-title-link">
    <h3 class:list={["dc-title display", featured ? "h2" : "h3"]}>{d.title}</h3>
  </a>
  <p class="dc-excerpt">{d.excerpt}</p>
  <div class="dc-meta mono">
    <span class="dc-loc"><Icon name="pin" size={13} /> {d.location}</span>
    <span class="dc-dot">·</span>
    <span>{date}</span>
    <span class="dc-dot">·</span>
    <span>{d.readTime}</span>
  </div>
  <a href={`/dispatches/${d.slug}/`} class="link-arrow dc-link">Read Dispatch <Icon name="arrow" size={16} /></a>
</article>

<style>
  .dispatch-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.25s ease, transform 0.25s var(--ease);
  }
  .dispatch-card:hover { border-color: rgba(255, 35, 64, 0.45); transform: translateY(-4px); }
  .dispatch-card.is-featured {
    background:
      linear-gradient(180deg, rgba(255, 35, 64, 0.06), transparent 45%),
      var(--surface);
  }
  .dc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
  }
  .dc-class { font-size: 0.62rem; letter-spacing: 0.18em; color: var(--dim); text-transform: uppercase; }
  .dc-title-link { color: var(--ink); display: block; }
  .dc-title { transition: color 0.2s ease; }
  .dc-title-link:hover .dc-title { color: var(--red-bright); }
  .dc-excerpt { color: var(--muted); font-size: 0.95rem; flex: 1; }
  .dc-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
  }
  .dc-loc { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--amber); }
  .dc-dot { opacity: 0.4; }
  .dc-link { margin-top: 0.3rem; }
</style>
