---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { site, services, nav, locations } from "../data/site";
const year = 2026;
---

<footer class="site-footer">
  <div class="hazard-strip"></div>
  <div class="container">
    <div class="foot-grid">
      <div class="foot-brand">
        <Logo />
        <p class="foot-blurb">
          Web design, SEO, and digital marketing for Northern Nevada. We build a
          system — web that ranks, SEO that compounds, and marketing that brings
          the right customers to your door.
        </p>
        <div class="foot-channels" aria-label="Social">
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook"><Icon name="facebook" size={20} /></a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" size={20} /></a>
          <a href={site.social.x} target="_blank" rel="noopener" aria-label="X"><Icon name="x" size={18} /></a>
          <a href={site.social.nextdoor} target="_blank" rel="noopener" aria-label="Nextdoor"><Icon name="nextdoor" size={20} /></a>
        </div>
      </div>

      <div class="foot-col">
        <h3 class="foot-h">Services</h3>
        <ul>
          {services.map((s) => (
            <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
          ))}
          <li><a href="/services/">All services</a></li>
        </ul>
      </div>

      <div class="foot-col">
        <h3 class="foot-h">Service Areas</h3>
        <ul>
          {locations.slice(0, 7).map((l) => (
            <li><a href={`/locations/${l.slug}/`}>{l.name}</a></li>
          ))}
          <li class="foot-sub">Services by city</li>
          <li><a href="/locations/carson-city/web-design/">Web Design in Carson City</a></li>
          <li><a href="/locations/reno/web-design/">Web Design in Reno</a></li>
          <li><a href="/locations/carson-city/seo/">SEO in Carson City</a></li>
          <li><a href="/locations/reno/seo/">SEO in Reno</a></li>
        </ul>
      </div>

      <div class="foot-col foot-comms">
        <h3 class="foot-h">Get in touch</h3>
        <ul>
          <li><Icon name="phone" size={16} /> <a href={site.phone.href}>{site.phone.display}</a></li>
          <li><Icon name="mail" size={16} /> <a href={`mailto:${site.email}`}>{site.email}</a></li>
          <li><Icon name="pin" size={16} /> <span>{site.address.street}, {site.address.locality}, {site.address.region} {site.address.postalCode}</span></li>
          <li><Icon name="map" size={16} /> <a href={site.maps} target="_blank" rel="noopener">Find us on Google</a></li>
        </ul>
        <a href="/contact/" class="btn btn-primary mt-2"><Icon name="rocket" size={15} /> Start a Project</a>
      </div>
    </div>

    <div class="foot-tagline mono">
      <span><span class="status-dot"></span> {site.tagline.toUpperCase()}</span>
      <span class="foot-sep">//</span>
      <span class="dim">WEB · SEO · DIGITAL MARKETING · NORTHERN NEVADA</span>
    </div>

    <div class="foot-bottom mono">
      <p>© {year} {site.brand}. Based in Carson City, Nevada.</p>
      <p class="dim">{site.domain}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:
      radial-gradient(700px 300px at 85% 0%, rgba(232, 92, 151, 0.08), transparent 60%),
      var(--void-2);
    border-top: 1px solid var(--line);
    margin-top: auto;
    position: relative;
  }
  .site-footer .hazard-strip { position: absolute; top: -6px; left: 0; right: 0; }
  .site-footer > .container { padding-block: clamp(3rem, 6vw, 4.5rem) 1.6rem; }

  .foot-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.5fr;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .foot-blurb { margin-top: 1.1rem; max-width: 36ch; color: var(--muted); font-size: 0.95rem; }
  .foot-channels { display: flex; gap: 1.1rem; margin-top: 1.3rem; }
  .foot-channels a { color: var(--muted); }
  .foot-channels a:hover { color: var(--cyan); }

  .foot-h {
    color: var(--ink);
    font-size: 0.72rem;
    font-family: var(--font-mono);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.1rem;
  }
  .foot-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .foot-col a { color: var(--muted); font-size: 0.92rem; }
  .foot-col a:hover { color: var(--ink); }
  .foot-sub { color: var(--dim); font-family: var(--font-mono); font-size: 0.62rem; letter-spacing: 0.16em; text-transform: uppercase; margin-top: 0.9rem; }

  .foot-comms ul li { display: flex; align-items: center; gap: 0.6rem; color: var(--muted); font-size: 0.9rem; }
  .foot-comms :global(svg) { color: var(--red); flex: none; }
  .foot-comms span { font-size: 0.86rem; }

  .foot-tagline {
    margin-top: 2.6rem;
    padding: 0.8rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .foot-sep { color: var(--red); }

  .foot-bottom {
    margin-top: 1.4rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .foot-grid { grid-template-columns: 1fr 1fr; }
    .foot-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .foot-grid { grid-template-columns: 1fr; }
    .foot-bottom { flex-direction: column; }
  }
</style>
