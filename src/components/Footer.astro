---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";
import { site, shows, nav } from "../data/site";
const year = 2026;
---

<footer class="site-footer">
  <div class="hazard-strip"></div>
  <div class="container">
    <div class="foot-grid">
      <div class="foot-brand">
        <Logo />
        <p class="foot-blurb">
          A veteran media collective broadcasting from the edge of the signal.
          Field dispatches, long-form radio, and supply for the observant.
        </p>
        <div class="foot-channels" aria-label="Channels">
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube"><Icon name="youtube" size={20} /></a>
          <a href={site.social.spotify} target="_blank" rel="noopener" aria-label="Spotify"><Icon name="spotify" size={20} /></a>
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" size={20} /></a>
          <a href={site.social.x} target="_blank" rel="noopener" aria-label="X"><Icon name="x" size={20} /></a>
          <a href={site.social.tiktok} target="_blank" rel="noopener" aria-label="TikTok"><Icon name="tiktok" size={20} /></a>
        </div>
      </div>

      <div class="foot-col">
        <h3 class="foot-h">Broadcast <span class="jp">放送</span></h3>
        <ul>
          {shows.map((s) => (
            <li><a href="/broadcast/">{s.name}</a></li>
          ))}
        </ul>
      </div>

      <div class="foot-col">
        <h3 class="foot-h">Navigation <span class="jp">索引</span></h3>
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="foot-col foot-comms">
        <h3 class="foot-h">Comms <span class="jp">連絡</span></h3>
        <ul>
          <li>
            <Icon name="mail" size={16} />
            <a href={`mailto:${site.email}`}>{site.email}</a>
          </li>
          <li>
            <Icon name="terminal" size={16} />
            <span>Mirror the Vault. Don't trust the tower.</span>
          </li>
        </ul>
        <a href="/contact/" class="btn btn-ghost mt-2"><Icon name="send" size={15} /> Open Channel</a>
      </div>
    </div>

    <div class="foot-transmission mono">
      <span><span class="status-dot"></span> TRANSMISSION ACTIVE</span>
      <span class="foot-sep">//</span>
      <span>{site.mottoJp} · {site.tagline.toUpperCase()}</span>
      <span class="foot-sep">//</span>
      <span class="dim">TRANSMISSIONS DRAMATIZED · THE SIGNAL IS REAL</span>
    </div>

    <div class="foot-bottom mono">
      <p>© {year} {site.brand}. All frequencies reserved.</p>
      <p class="dim">{site.domain} · {site.callsign}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background:
      radial-gradient(700px 300px at 85% 0%, rgba(255, 35, 64, 0.08), transparent 60%),
      var(--void-2);
    border-top: 1px solid var(--line);
    margin-top: auto;
    position: relative;
  }
  .site-footer .hazard-strip { position: absolute; top: -6px; left: 0; right: 0; }
  .site-footer > .container { padding-block: clamp(3rem, 6vw, 4.5rem) 1.6rem; }

  .foot-grid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1.4fr;
    gap: clamp(1.5rem, 4vw, 3rem);
  }
  .foot-blurb { margin-top: 1.1rem; max-width: 34ch; color: var(--muted); font-size: 0.95rem; }
  .foot-channels { display: flex; gap: 1.1rem; margin-top: 1.3rem; }
  .foot-channels a { color: var(--muted); }
  .foot-channels a:hover { color: var(--cyan); }

  .foot-h {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    font-size: 0.72rem;
    font-family: var(--font-mono);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 1.1rem;
  }
  .foot-h .jp { color: var(--amber); letter-spacing: 0.1em; }
  .foot-col ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .foot-col a { color: var(--muted); font-size: 0.92rem; }
  .foot-col a:hover { color: #fff; }

  .foot-comms ul li { display: flex; align-items: center; gap: 0.6rem; color: var(--muted); font-size: 0.92rem; }
  .foot-comms :global(svg) { color: var(--red); flex: none; }

  .foot-transmission {
    margin-top: 2.6rem;
    padding: 0.8rem 0;
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.7rem;
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .foot-sep { color: var(--red); }

  .foot-bottom {
    margin-top: 1.4rem;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .foot-grid { grid-template-columns: 1fr 1fr; }
    .foot-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 520px) {
    .foot-grid { grid-template-columns: 1fr; }
    .foot-bottom { flex-direction: column; }
  }
</style>
