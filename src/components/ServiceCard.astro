---
import Icon from "./Icon.astro";
import type { Service } from "../data/site";
interface Props { service: Service; featured?: boolean; }
const { service, featured = false } = Astro.props;
---
<a href={`/services/${service.slug}/`} class:list={["card card-hover service-card", { featured }]}>
  <span class="media is-3x2 zoomable service-media">
    <img src={service.image} alt={service.imageAlt} width="1500" height="1000" loading="lazy" decoding="async" />
    <span class="service-icon" aria-hidden="true"><Icon name={service.icon} size={20} /></span>
  </span>
  <span class="service-body">
    <h3 class="service-title">{service.title}</h3>
    <p class="service-tag">{service.tagline}</p>
    <p class="service-desc">{service.intro}</p>
    <span class="link-arrow">Learn more <Icon name="arrow" size={16} /></span>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    padding: 0;
    overflow: hidden;
  }
  .service-media { border-radius: 0; aspect-ratio: 3 / 2; }
  .service-icon {
    position: absolute;
    left: 0.9rem;
    bottom: 0.9rem;
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.92);
    color: var(--brand-700);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(4px);
  }
  .service-body {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
    flex: 1;
  }
  .service-title { font-size: 1.25rem; color: var(--ink); }
  .service-tag { color: var(--brand-700); font-weight: 600; font-size: 0.92rem; }
  .service-desc {
    color: var(--body);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .service-card .link-arrow { margin-top: 0.3rem; }
  .service-card.featured { border-color: var(--brand-300); box-shadow: var(--shadow-md); }
</style>
