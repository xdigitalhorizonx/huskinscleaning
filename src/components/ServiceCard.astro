---
import Icon from "./Icon.astro";
import type { Service } from "../data/site";
interface Props { service: Service; }
const { service: s } = Astro.props;
const colorVar = `var(--${s.color})`;
---

<article class="service-card panel panel-hover" id={s.slug} style={`--accent:${colorVar}`}>
  <div class="sc-top">
    <span class="sc-icon"><Icon name={s.icon} size={24} /></span>
    <span class="sc-num mono">{s.num} / {s.name}</span>
  </div>
  <h3 class="h3 sc-name">{s.tagline}</h3>
  <p class="sc-desc">{s.desc}</p>
  <ul class="sc-list">
    {s.bullets.map((b) => (
      <li><Icon name="check" size={14} class="sc-check" /> {b}</li>
    ))}
  </ul>
  <a href={`/services/${s.slug}/`} class="link-arrow sc-link">Explore {s.name} <Icon name="arrow" size={16} /></a>
</article>

<style>
  .service-card { display: flex; flex-direction: column; gap: 0.85rem; scroll-margin-top: 7rem; }
  .service-card::before, .service-card::after { border-color: var(--accent); }
  .sc-top { display: flex; align-items: center; gap: 0.8rem; }
  .sc-icon {
    display: grid;
    place-items: center;
    width: 3rem; height: 3rem;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
    flex: none;
  }
  .sc-num { color: var(--accent); font-size: 0.72rem; letter-spacing: 0.14em; text-transform: uppercase; }
  .sc-name { font-size: 1.3rem; }
  .sc-desc { color: var(--muted); font-size: 0.95rem; }
  .sc-list { list-style: none; padding: 0; margin: 0.2rem 0 0; display: grid; gap: 0.55rem; flex: 1; }
  .sc-list li { display: flex; align-items: center; gap: 0.6rem; color: var(--body); font-size: 0.92rem; }
  .sc-list :global(.sc-check) { color: var(--accent); flex: none; }
  .sc-link { margin-top: 0.4rem; color: var(--accent); padding-top: 0.8rem; border-top: 1px solid var(--line); }
</style>
