---
import Icon from "./Icon.astro";
import type { Service } from "../data/site";
interface Props { service: Service; featured?: boolean; }
const { service, featured = false } = Astro.props;
---
<a href={`/services/${service.slug}/`} class:list={["card card-hover service-card", { featured }]}>
  <span class="media is-4x3 zoomable service-media">
    <img src={service.image} alt={service.imageAlt} width="1500" height="1000" loading="lazy" decoding="async" />
    <span class="service-icon" aria-hidden="true"><Icon name={service.icon} size={19} /></span>
  </span>
  <span class="service-body">
    <h3 class="service-title">{service.title}</h3>
    <p class="service-tag">{service.tagline}</p>
    <span class="link-arrow">Learn more <Icon name="arrow" size={15} /></span>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    padding: 0;
    overflow: hidden;
  }
  .service-media { border-radius: 0; aspect-ratio: 4 / 3; }
  .service-icon {
    position: absolute;
    left: 0.7rem;
    bottom: 0.7rem;
    display: grid;
    place-items: center;
    width: 2.3rem;
    height: 2.3rem;
    border-radius: 11px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--brand-700);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(4px);
  }
  .service-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1rem 1.05rem 1.15rem;
    flex: 1;
  }
  .service-title {
    font-size: 1.08rem;
    line-height: 1.2;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .service-tag {
    color: var(--brand-700);
    font-weight: 600;
    font-size: 0.86rem;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .service-card .link-arrow { margin-top: auto; padding-top: 0.2rem; font-size: 0.88rem; }
  .service-card.featured { border-color: var(--brand-300); box-shadow: var(--shadow-md); }
</style>
