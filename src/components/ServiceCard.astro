---
import Icon from "./Icon.astro";
import type { Service } from "../data/site";
interface Props { service: Service; featured?: boolean; }
const { service, featured = false } = Astro.props;

// Uniform thumbnail shown on every service card (compact grid).
const THUMB = "/images/house-cleaning.webp";
const THUMB_ALT = "Huskins Cleaning — professional cleaning services in Omaha";
---
<a href={`/services/${service.slug}/`} class:list={["card card-hover service-card", { featured }]}>
  <span class="media is-4x3 zoomable service-media">
    <img src={THUMB} alt={THUMB_ALT} width="1500" height="1000" loading="lazy" decoding="async" />
    <span class="service-icon" aria-hidden="true"><Icon name={service.icon} size={18} /></span>
  </span>
  <span class="service-body">
    <h3 class="service-title">{service.title}</h3>
    <span class="link-arrow">Learn more <Icon name="arrow" size={14} /></span>
  </span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    text-decoration: none;
    padding: 0;
    overflow: hidden;
  }
  .service-media { border-radius: 0; aspect-ratio: 4 / 3; }
  .service-icon {
    position: absolute;
    left: 0.6rem;
    bottom: 0.6rem;
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
    border-radius: 9px;
    background: rgba(255, 255, 255, 0.94);
    color: var(--brand-700);
    box-shadow: var(--shadow-sm);
    backdrop-filter: blur(4px);
  }
  .service-body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 0.8rem 0.9rem 0.95rem;
    flex: 1;
  }
  .service-title {
    font-size: 1rem;
    line-height: 1.2;
    color: var(--ink);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .service-card .link-arrow { margin-top: auto; font-size: 0.85rem; }
  .service-card.featured { border-color: var(--brand-300); box-shadow: var(--shadow-md); }
</style>
