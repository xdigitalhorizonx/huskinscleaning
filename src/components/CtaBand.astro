---
import Icon from "./Icon.astro";
import { site } from "../data/site";
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Ready for a home that feels brand new?",
  text = "Get a fast, no-obligation quote today. Friendly local team, honest pricing, and a spotless result guaranteed.",
} = Astro.props;
---

<section class="section cta-band section-dark">
  <div class="container cta-inner">
    <div class="cta-copy">
      <span class="eyebrow is-light">Get Started</span>
      <h2 class="h2">{heading}</h2>
      <p class="lead">{text}</p>
      <ul class="cta-points">
        <li><Icon name="check-circle" size={18} /> Free, no-pressure quotes</li>
        <li><Icon name="check-circle" size={18} /> Same trusted, insured crew</li>
        <li><Icon name="check-circle" size={18} /> 100% satisfaction guarantee</li>
      </ul>
    </div>
    <div class="cta-actions">
      <a href="/contact/" class="btn btn-accent btn-lg">Get My Free Quote</a>
      <a href={site.phone.href} class="btn btn-outline-light btn-lg">
        <Icon name="phone" size={20} /> {site.phone.display}
      </a>
      <p class="cta-note"><Icon name="clock" size={15} /> {site.hours.label}</p>
    </div>
  </div>
</section>

<style>
  .cta-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .cta-copy .h2 { margin-top: 0.7rem; }
  .cta-copy .lead { margin-top: 0.8rem; max-width: 44ch; }
  .cta-points {
    list-style: none;
    padding: 0;
    margin-top: 1.4rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 1.4rem;
  }
  .cta-points li {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--on-dark);
    font-weight: 600;
  }
  .cta-points :global(svg) { color: var(--brand-300); }
  .cta-actions { display: grid; gap: 0.8rem; justify-items: stretch; }
  .cta-note {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    justify-content: center;
    color: var(--on-dark-muted);
    font-size: 0.85rem;
    margin-top: 0.2rem;
  }
  @media (max-width: 820px) {
    .cta-inner { grid-template-columns: 1fr; }
  }
</style>
