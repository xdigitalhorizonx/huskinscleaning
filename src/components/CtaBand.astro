---
import Icon from "./Icon.astro";
import { site } from "../data/site";
interface Props {
  heading?: string;
  text?: string;
}
const {
  heading = "Get on the net before they cut it again.",
  text = "New transmissions, field dispatches, and limited supply drops — straight to your channel. No tower lasts forever; mirror what matters.",
} = Astro.props;
---

<section class="section cta-band scanlines">
  <div class="grid-floor"></div>
  <div class="container">
    <div class="cta-panel panel is-red">
      <div class="cta-copy">
        <span class="eyebrow is-red">Handoff <span class="jp">受信</span></span>
        <h2 class="h2 display mt-1">{heading}</h2>
        <p class="lead mt-2">{text}</p>
      </div>
      <div class="cta-actions">
        <a href="/broadcast/" class="btn btn-primary btn-lg"><Icon name="play" size={18} /> Watch Live</a>
        <a href={site.social.spotify} target="_blank" rel="noopener" class="btn btn-ghost btn-lg"><Icon name="headphones" size={18} /> Subscribe</a>
        <p class="cta-note mono"><span class="status-dot"></span> {site.callsign} · {site.tagline.toUpperCase()}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    position: relative;
    overflow: hidden;
    border-block: 1px solid var(--line);
    background:
      radial-gradient(600px 300px at 80% 100%, rgba(34, 224, 255, 0.08), transparent 60%),
      var(--void-2);
  }
  .cta-panel {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
    position: relative;
    z-index: 3;
    background:
      linear-gradient(180deg, rgba(255, 35, 64, 0.06), transparent 50%),
      var(--surface);
  }
  .cta-copy .lead { max-width: 46ch; }
  .cta-actions { display: grid; gap: 0.8rem; }
  .cta-note {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-top: 0.3rem;
  }
  @media (max-width: 820px) {
    .cta-panel { grid-template-columns: 1fr; }
  }
</style>
