---
/**
 * Digital Horizon emblem + wordmark.
 * An original mark: a neon sun rising over a horizon line, in the site's
 * dark-tech style.
 */
interface Props {
  compact?: boolean;
  class?: string;
}
const { compact = false, class: className = "" } = Astro.props;
---

<a href="/" class={`logo ${className}`} aria-label="Digital Horizon — home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 44 44" width="44" height="44" fill="none">
      <defs>
        <linearGradient id="sun" x1="0" y1="8" x2="0" y2="32" gradientUnits="userSpaceOnUse">
          <stop stop-color="#ffb733" />
          <stop offset="1" stop-color="#ff5a3c" />
        </linearGradient>
      </defs>
      <!-- rays -->
      <g class="rays" stroke="#ff9d00" stroke-width="1.6" stroke-linecap="round">
        <path d="M22 4.5V9" />
        <path d="M10.5 8.5 13.5 12" />
        <path d="M33.5 8.5 30.5 12" />
      </g>
      <!-- sun -->
      <circle class="sun" cx="22" cy="22.5" r="8.5" fill="url(#sun)" />
      <!-- horizon + reflection -->
      <path class="horizon" d="M5 27.5H39" stroke="#22e0ff" stroke-width="2.4" stroke-linecap="round" />
      <path class="horizon2" d="M12 32H32" stroke="#22e0ff" stroke-width="1.6" stroke-linecap="round" opacity="0.45" />
    </svg>
  </span>
  {!compact && (
    <span class="logo-text">
      <span class="logo-word">Digital <b>Horizon</b></span>
      <span class="logo-sub">WEB · SEO · MARKETING</span>
    </span>
  )}
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 0.7rem; text-decoration: none; }
  .logo-mark { line-height: 0; flex: none; }
  .logo-mark svg { width: 40px; height: 40px; }
  .sun { filter: drop-shadow(0 0 5px rgba(232, 92, 151, 0.7)); }
  .horizon { filter: drop-shadow(0 0 4px rgba(79, 147, 218, 0.6)); }
  .logo:hover .rays { stroke: var(--amber-bright); }
  .logo:hover .sun { filter: drop-shadow(0 0 8px rgba(255, 122, 94, 0.9)); }

  .logo-text { display: flex; flex-direction: column; line-height: 1.05; }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.12rem;
    letter-spacing: 0.01em;
    color: var(--ink);
  }
  .logo-word b { font-weight: 700; color: var(--amber-bright); }
  .logo-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.24em;
    color: var(--muted);
    margin-top: 1px;
  }
  @media (max-width: 420px) { .logo-word { font-size: 1rem; } }
</style>
