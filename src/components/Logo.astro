---
/**
 * Digital Horizon emblem + wordmark.
 * Mark: three tapered, rounded bars (pink / blue / green).
 * Wordmark: bold rounded "Digital Horizon".
 */
interface Props {
  compact?: boolean;
  class?: string;
}
const { compact = false, class: className = "" } = Astro.props;
---

<a href="/" class={`logo ${className}`} aria-label="Digital Horizon — home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 48 44" width="48" height="44" fill="none" stroke-linecap="round">
      <line class="bar bar-1" x1="6"  y1="11" x2="42" y2="11" />
      <line class="bar bar-2" x1="14" y1="22" x2="34" y2="22" />
      <line class="bar bar-3" x1="19" y1="33" x2="29" y2="33" />
    </svg>
  </span>
  {!compact && <span class="logo-word">Digital Horizon</span>}
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 0.6rem; text-decoration: none; }
  .logo-mark { line-height: 0; flex: none; }
  .logo-mark svg { width: 40px; height: 37px; }
  .bar { stroke-width: 7; transition: transform 0.25s var(--ease); transform-origin: center; }
  .bar-1 { stroke: #f28cb4; }
  .bar-2 { stroke: #5ea9ea; }
  .bar-3 { stroke: #7ecf97; }
  .logo:hover .bar-1 { transform: scaleX(1.06); }
  .logo:hover .bar-3 { transform: scaleX(1.2); }

  .logo-word {
    font-family: "Nunito", var(--font-display), sans-serif;
    font-weight: 800;
    font-size: 1.42rem;
    letter-spacing: -0.015em;
    color: var(--ink);
    white-space: nowrap;
    line-height: 1;
  }
  @media (max-width: 420px) { .logo-word { font-size: 1.2rem; } .logo-mark svg { width: 34px; height: 31px; } }
</style>
