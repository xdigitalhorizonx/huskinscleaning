---
/**
 * Forward Observations Group emblem + wordmark.
 * An original mecha-HUD mark: hexagonal frame, twin glowing NVG "eyes",
 * and a forward/artillery chevron. Evokes the brand's NVG-skull motif
 * without reproducing it.
 */
interface Props {
  compact?: boolean;
  class?: string;
}
const { compact = false, class: className = "" } = Astro.props;
---

<a href="/" class={`logo ${className}`} aria-label="Forward Observations Group — home">
  <span class="logo-mark" aria-hidden="true">
    <svg viewBox="0 0 44 44" width="44" height="44" fill="none">
      <!-- hex frame -->
      <path class="hex" d="M22 2.5 40 12.5V31.5L22 41.5 4 31.5V12.5Z" />
      <path class="hex-in" d="M22 7 35.5 14.5V29.5L22 37 8.5 29.5V14.5Z" opacity="0.5" />
      <!-- twin NVG tubes / eyes -->
      <circle class="eye" cx="16.5" cy="20" r="3.1" />
      <circle class="eye" cx="27.5" cy="20" r="3.1" />
      <path class="brow" d="M11.5 15.5 17 13.5M32.5 15.5 27 13.5" />
      <!-- skull jaw ticks -->
      <path class="jaw" d="M17 27h10M18.5 27v2.4M22 27v3M25.5 27v2.4" />
      <!-- forward chevron -->
      <path class="chev" d="M13.5 33 22 38.5 30.5 33" />
    </svg>
  </span>
  {!compact && (
    <span class="logo-text">
      <span class="logo-word">
        <b>FORWARD</b><span class="logo-slash">//</span><b>OBSERVATIONS</b>
      </span>
      <span class="logo-sub">GROUP<span class="jp">前線観測</span></span>
    </span>
  )}
</a>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
  }
  .logo-mark { line-height: 0; flex: none; }
  .logo-mark svg { width: 40px; height: 40px; }

  .hex { stroke: var(--amber); stroke-width: 1.6; }
  .hex-in { stroke: var(--amber); stroke-width: 1; }
  .eye {
    fill: var(--cyan);
    filter: drop-shadow(0 0 4px var(--cyan));
  }
  .brow, .jaw { stroke: var(--ink); stroke-width: 1.4; stroke-linecap: round; }
  .chev { stroke: var(--red); stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

  .logo:hover .eye { fill: var(--red); filter: drop-shadow(0 0 5px var(--red)); }
  .logo:hover .hex { stroke: var(--red); }

  .logo-text { display: flex; flex-direction: column; line-height: 1.02; }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.02rem;
    letter-spacing: 0.02em;
    color: var(--ink);
    display: inline-flex;
    align-items: baseline;
  }
  .logo-slash { color: var(--red); margin: 0 0.12em; }
  .logo-sub {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.32em;
    color: var(--muted);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1px;
  }
  .logo-sub .jp { color: var(--amber); letter-spacing: 0.14em; font-size: 0.66rem; }

  @media (max-width: 420px) {
    .logo-word { font-size: 0.9rem; }
  }
</style>
