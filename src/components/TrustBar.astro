---
import { trustPoints } from "../data/site";
---
<div class="trust-bar">
  <div class="container trust-grid">
    {trustPoints.map((t) => (
      <div class="trust-item">
        <span class="trust-stat">{t.stat}</span>
        <span class="trust-label">{t.label}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .trust-bar {
    background: var(--surface);
    border-block: 1px solid var(--line);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    padding-block: 1.6rem;
  }
  .trust-item {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    position: relative;
  }
  .trust-item + .trust-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 15%;
    height: 70%;
    width: 1px;
    background: var(--line);
  }
  .trust-stat {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.4rem, 3vw, 2rem);
    color: var(--brand-700);
    letter-spacing: -0.02em;
  }
  .trust-label {
    font-size: 0.82rem;
    color: var(--muted);
    font-weight: 500;
  }
  @media (max-width: 620px) {
    .trust-grid { grid-template-columns: repeat(2, 1fr); gap: 1.4rem 1rem; }
    .trust-item:nth-child(odd)::before { display: none; }
  }
</style>
