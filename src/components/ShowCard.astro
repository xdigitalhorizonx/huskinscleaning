---
import Icon from "./Icon.astro";
import type { Show } from "../data/site";
interface Props { show: Show; }
const { show } = Astro.props;
const colorVar = `var(--${show.color === "violet" ? "violet" : show.color})`;
---

<article class="show-card panel panel-hover" style={`--accent:${colorVar}`}>
  <div class="show-top">
    <span class="show-icon"><Icon name={show.icon} size={24} /></span>
    <span class="show-jp mono">{show.jp}</span>
  </div>
  <h3 class="h3 show-name">{show.name}</h3>
  <p class="show-tag">{show.tagline}</p>
  <p class="show-desc">{show.desc}</p>
  <div class="show-meta mono">
    <span><Icon name="film" size={13} /> {show.format}</span>
    <span><Icon name="clock" size={13} /> {show.cadence}</span>
  </div>
  <a href="/broadcast/" class="link-arrow show-link">Tune In <Icon name="arrow" size={16} /></a>
</article>

<style>
  .show-card {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .show-card::before, .show-card::after { border-color: var(--accent); }
  .show-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .show-icon {
    display: grid;
    place-items: center;
    width: 3rem; height: 3rem;
    color: var(--accent);
    border: 1px solid color-mix(in srgb, var(--accent) 45%, transparent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
    clip-path: polygon(0 0, calc(100% - 8px) 0, 100% 8px, 100% 100%, 8px 100%, 0 calc(100% - 8px));
  }
  .show-jp { color: var(--accent); font-size: 0.7rem; letter-spacing: 0.16em; }
  .show-name { margin-top: 0.2rem; }
  .show-tag {
    color: var(--accent);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
  }
  .show-desc { color: var(--muted); font-size: 0.94rem; flex: 1; }
  .show-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.2rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--dim);
    padding-top: 0.6rem;
    border-top: 1px solid var(--line);
  }
  .show-meta span { display: inline-flex; align-items: center; gap: 0.4rem; }
  .show-link { margin-top: 0.2rem; color: var(--accent); }
</style>
