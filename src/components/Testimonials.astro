---
import Icon from "./Icon.astro";
import Stars from "./Stars.astro";
import { testimonials, site } from "../data/site";
interface Props { compact?: boolean; }
const { compact = false } = Astro.props;
const items = compact ? testimonials.slice(0, 3) : testimonials;
---

<section class="section" id="reviews">
  <div class="container">
    <div class="section-head is-center">
      <span class="eyebrow">Reviews</span>
      <h2 class="h2">Omaha homeowners keep coming back</h2>
      <p class="lead">
        Real words from real neighbors. It's why so much of our work comes from
        referrals and repeat clients.
      </p>
    </div>

    <div class="grid grid-3 mt-6">
      {items.map((t) => (
        <figure class="card review-card">
          <Icon name="quote" class="review-quote" size={30} />
          <Stars />
          <blockquote>“{t.quote}”</blockquote>
          <figcaption>
            <span class="review-avatar" aria-hidden="true">{t.author.charAt(0)}</span>
            <span>
              <strong>{t.author}</strong>
              <small>{t.location} · {t.service}</small>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>

    <div class="review-cta">
      <div class="review-rating">
        <Stars />
        <span><strong>{site.rating.value}</strong> average from {site.rating.count}+ happy customers</span>
      </div>
      <a href="/reviews/" class="link-arrow">Read more reviews <Icon name="arrow" size={16} /></a>
    </div>
  </div>
</section>

<style>
  .review-card { display: flex; flex-direction: column; position: relative; overflow: hidden; }
  .review-card :global(.review-quote) {
    color: var(--brand-100);
    position: absolute;
    top: 1rem;
    right: 1.1rem;
  }
  .review-card blockquote {
    margin: 0.8rem 0 1.2rem;
    font-size: 1.05rem;
    color: var(--ink);
    line-height: 1.55;
    flex: 1;
  }
  figcaption { display: flex; align-items: center; gap: 0.75rem; }
  .review-avatar {
    display: grid;
    place-items: center;
    width: 2.6rem;
    height: 2.6rem;
    border-radius: 50%;
    background: linear-gradient(145deg, var(--brand-400), var(--brand-700));
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    flex: none;
  }
  figcaption strong { display: block; color: var(--ink); font-family: var(--font-display); }
  figcaption small { color: var(--muted); font-size: 0.82rem; }

  .review-cta {
    margin-top: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    padding: 1.2rem 1.6rem;
    background: var(--surface-2);
    border-radius: var(--radius-lg);
  }
  .review-rating { display: inline-flex; align-items: center; gap: 0.7rem; color: var(--body); }
  .review-rating strong { color: var(--ink); font-size: 1.15rem; }
</style>
