---
import Icon from "./Icon.astro";
interface Props {
  crumbs: { name: string; url: string }[];
}
const { crumbs } = Astro.props;
---
<nav class="breadcrumbs mono" aria-label="Breadcrumb">
  <ol>
    {crumbs.map((c, i) => (
      <li>
        {i < crumbs.length - 1 ? (
          <>
            <a href={c.url}>{c.name}</a>
            <Icon name="chevron-right" class="bc-sep" size={12} />
          </>
        ) : (
          <span aria-current="page">{c.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 1.4rem;
  }
  .breadcrumbs ol {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .breadcrumbs li { display: inline-flex; align-items: center; gap: 0.4rem; }
  .breadcrumbs a { color: var(--muted); }
  .breadcrumbs a:hover { color: var(--cyan); }
  .breadcrumbs span[aria-current] { color: var(--amber); }
  .breadcrumbs :global(.bc-sep) { color: var(--red); opacity: 0.7; }
</style>
