---
import "@fontsource-variable/inter";
import "@fontsource/chakra-petch/400.css";
import "@fontsource/chakra-petch/500.css";
import "@fontsource/chakra-petch/600.css";
import "@fontsource/chakra-petch/700.css";
import "@fontsource/share-tech-mono/400.css";
import "@fontsource-variable/orbitron";
import "@fontsource/noto-sans-jp/500.css";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import EasterEgg from "../components/EasterEgg.astro";
import { site } from "../data/site";
import { organizationSchema, websiteSchema } from "../lib/schema";

interface Props {
  title: string;
  description: string;
  /** Path only, e.g. "/broadcast/". Defaults to current URL. */
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Extra JSON-LD nodes for this page (breadcrumbs, article...). */
  schema?: object[];
}

const {
  title,
  description,
  canonical,
  ogImage = "/og-image.png",
  noindex = false,
  schema = [],
} = Astro.props;

const canonicalURL = new URL(canonical ?? Astro.url.pathname, site.url).href;
const ogImageURL = new URL(ogImage, site.url).href;

const graph = [organizationSchema(), websiteSchema(), ...schema];
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="author" content={site.brand} />
    <meta name="theme-color" content="#05060a" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.brand} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    {graph.map((node) => (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <EasterEgg />
  </body>
</html>
